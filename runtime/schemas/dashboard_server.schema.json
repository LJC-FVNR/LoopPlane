{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LoopPlane dashboard_server.json",
  "type": "object",
  "required": [
    "schema_version",
    "ok",
    "status",
    "server_mode",
    "project_root",
    "workspace_id",
    "workflow_id",
    "selected_workflow_id",
    "current_workflow_id",
    "selection_scope",
    "started_at",
    "host",
    "port",
    "url",
    "api_base_url",
    "pid",
    "token_required",
    "mutating_api_requires_token",
    "same_origin_required",
    "server_state_file"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["1.5", "1.6"]},
    "ok": {"type": "boolean"},
    "status": {"type": "string", "enum": ["serving", "stopped", "failed", "stale"]},
    "server_mode": {"type": "boolean"},
    "project_root": {"type": "string", "minLength": 1},
    "workspace_id": {"type": "string", "pattern": "^ws_[0-9A-Za-z][0-9A-Za-z_-]{7,63}$"},
    "workflow_id": {"type": "string", "pattern": "^wf_[0-9]{8}_[0-9a-f]{8}$"},
    "selected_workflow_id": {"type": "string", "pattern": "^wf_[0-9]{8}_[0-9a-f]{8}$"},
    "current_workflow_id": {"type": "string", "pattern": "^wf_[0-9]{8}_[0-9a-f]{8}$"},
    "selection_scope": {"type": "string", "enum": ["dashboard_visualization_only", "current_workflow"]},
    "started_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"},
    "host": {"type": "string", "enum": ["127.0.0.1", "localhost"]},
    "port": {"type": "integer", "minimum": 1, "maximum": 65535},
    "url": {"type": "string", "minLength": 1},
    "api_base_url": {"type": "string", "minLength": 1},
    "pid": {"type": "integer", "minimum": 1},
    "token": {"type": ["string", "null"]},
    "token_file": {"type": ["string", "null"]},
    "token_required": {"type": "boolean"},
    "mutating_api_requires_token": {"type": "boolean"},
    "same_origin_required": {"type": "boolean"},
    "server_state_file": {"type": "string", "minLength": 1},
    "errors": {"type": "array", "items": {"type": "string"}},
    "warnings": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
