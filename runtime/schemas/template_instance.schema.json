{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LoopPlane template instance",
  "type": "object",
  "required": [
    "schema_version",
    "kind",
    "workflow_id",
    "created_at",
    "created_by",
    "template",
    "inputs",
    "rendered_files",
    "activation"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "kind": {"const": "loopplane.template_instance"},
    "workflow_id": {"type": "string", "pattern": "^wf_[0-9]{8}_[0-9a-f]{8}$"},
    "created_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"},
    "created_by": {"type": "string", "minLength": 1},
    "template": {
      "type": "object",
      "required": ["id", "version", "source", "sha256"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "source": {"type": "string", "minLength": 1},
        "root": {"type": "string"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "preset": {
      "type": "object",
      "properties": {
        "name": {"type": ["string", "null"]},
        "path": {"type": ["string", "null"]},
        "sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "inputs": {"type": "object"},
    "policy": {"type": "object"},
    "rendered_files": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["sha256", "bytes"],
        "properties": {
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "bytes": {"type": "integer", "minimum": 0}
        },
        "additionalProperties": false
      }
    },
    "activation": {
      "type": "object",
      "required": ["direct_activation", "requires_activate_plan"],
      "properties": {
        "direct_activation": {"type": "boolean"},
        "requires_activate_plan": {"type": "boolean"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
