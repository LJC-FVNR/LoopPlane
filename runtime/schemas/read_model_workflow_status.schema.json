{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LoopPlane workflow_status read model",
  "type": "object",
  "required": ["schema_version", "workflow_id", "generated_at", "source_hashes", "status", "progress", "requires_attention"],
  "properties": {
    "schema_version": {"const": "1.5"},
    "workflow_id": {"type": "string"},
    "workflow_title": {"type": "string", "minLength": 1},
    "generated_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"},
    "source_hashes": {"type": "object"},
    "status": {"type": "string", "minLength": 1},
    "progress": {"type": "object"},
    "requires_attention": {"type": "array"}
  }
}
