{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LoopPlane workspace.json",
  "type": "object",
  "required": [
    "schema_version",
    "workspace_id",
    "project_root",
    "loopplane_dir",
    "repo_root",
    "created_at",
    "created_by_loopplane_version",
    "workspace_boundary",
    "allow_out_of_boundary_writes",
    "single_active_running_workflow"
  ],
  "properties": {
    "schema_version": {"const": "1.6"},
    "workspace_id": {"type": "string", "pattern": "^ws_[0-9A-Za-z][0-9A-Za-z_-]{7,63}$"},
    "project_root": {"const": "."},
    "loopplane_dir": {"const": ".loopplane"},
    "repo_root": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"},
    "created_by_loopplane_version": {"type": "string", "minLength": 1},
    "workspace_boundary": {"const": "project_root"},
    "allow_out_of_boundary_writes": {"type": "boolean"},
    "single_active_running_workflow": {"type": "boolean"},
    "layout": {"type": "string", "minLength": 1},
    "current_workflow_id": {"type": "string", "pattern": "^wf_[0-9]{8}_[0-9a-f]{8}$"}
  },
  "additionalProperties": true
}
