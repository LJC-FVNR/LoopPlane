{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LoopPlane read-model build manifest",
  "type": "object",
  "required": ["schema_version", "workflow_id", "generated_at", "builder_version", "source_hashes", "run_details"],
  "properties": {
    "schema_version": {"const": "1.5"},
    "workflow_id": {"type": "string"},
    "generated_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"},
    "last_event_seq": {"type": ["integer", "null"], "minimum": 0},
    "source_event_id": {"type": ["string", "null"]},
    "builder_version": {"type": "string", "minLength": 1},
    "source_hashes": {"type": "object"},
    "event_replay": {"type": "object"},
    "event_segment_manifest": {"type": "object"},
    "run_details": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["run_id", "path", "detail_source"],
        "properties": {
          "run_id": {"type": "string", "minLength": 1},
          "path": {"type": "string", "minLength": 1},
          "detail_source": {
            "type": "object",
            "required": ["schema_version", "fingerprint", "files"],
            "properties": {
              "schema_version": {"const": "1.5"},
              "fingerprint": {"type": "string", "pattern": "^sha256:"},
              "files": {"type": "array"}
            }
          },
          "detail_reused": {"type": "boolean"}
        }
      }
    }
  }
}
