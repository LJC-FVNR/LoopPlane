{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LoopPlane self expansion proposal",
  "type": "object",
  "required": [
    "schema_version",
    "proposal_id",
    "workflow_id",
    "trigger",
    "expansion_type",
    "resolution_strategy",
    "target_task_ids",
    "target_failure_ids",
    "new_tasks",
    "plan_patch_path",
    "approval_required",
    "confidence",
    "stop_condition"
  ],
  "properties": {
    "schema_version": {"const": "1.5"},
    "proposal_id": {"type": "string", "minLength": 1},
    "workflow_id": {"type": "string", "minLength": 1},
    "trigger": {"type": "string", "minLength": 1},
    "expansion_type": {
      "type": "string",
      "enum": [
        "evidence_gap",
        "failed_recovery_decomposition",
        "stale_or_partial_task",
        "missing_deliverable",
        "contradictory_results",
        "validation_gap",
        "scope_clarification_required",
        "final_verifier_retry",
        "no_executable_work",
        "objective_gap"
      ]
    },
    "resolution_strategy": {
      "type": "string",
      "enum": [
        "append_followup_only",
        "reopen_failure_after_new_evidence",
        "supersede_task_with_approval",
        "requires_human"
      ]
    },
    "target_task_ids": {"type": "array", "items": {"type": "string"}},
    "target_failure_ids": {"type": "array", "items": {"type": "string"}},
    "target_objective_ids": {"type": "array", "items": {"type": "string"}},
    "target_phase_id": {"type": "string"},
    "new_phase_id": {"type": "string"},
    "followup_phase_id": {"type": "string"},
    "plan_patch_operation": {
      "type": "string",
      "enum": [
        "append_to_end",
        "insert_task_into_phase",
        "insert_phase_before_final_objectives"
      ]
    },
    "objective_verification_report": {"type": "string"},
    "objective_gap_signature": {"type": "string"},
    "new_tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["task_id", "title", "status"],
        "properties": {
          "task_id": {"type": "string", "minLength": 1},
          "title": {"type": "string", "minLength": 1},
          "status": {"type": "string", "enum": ["[ ]", "[~]", "[!]", "[-]"]},
          "phase": {"type": "string"},
          "dependencies": {"type": "array", "items": {"type": "string"}},
          "objective_links": {"type": "array", "items": {"type": "string"}},
          "objective": {"type": "string"},
          "validation": {"type": "string"},
          "notes": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "plan_patch_path": {"type": "string", "minLength": 1},
    "approval_required": {"type": "boolean"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "risk": {"type": "string", "enum": ["low", "medium", "high"]},
    "loop_signature": {"type": "string", "minLength": 1},
    "loop_signature_fields": {"type": "object"},
    "stop_condition": {"type": "string", "minLength": 1},
    "rationale": {"type": "string"},
    "expected_evidence": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
