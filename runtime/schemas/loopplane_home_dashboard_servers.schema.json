{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LOOPPLANE_HOME dashboard servers index",
  "type": "object",
  "required": ["schema_version", "servers"],
  "properties": {
    "schema_version": {"const": "1.6"},
    "authority": {"const": "discovery_only"},
    "updated_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"},
    "servers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "schema_version": {"const": "1.6"},
          "authority": {"const": "discovery_only"},
          "record_type": {"const": "dashboard_server"},
          "status": {"type": "string"},
          "server_mode": {"type": "boolean"},
          "workspace_id": {"type": "string", "pattern": "^ws_[0-9A-Za-z][0-9A-Za-z_-]{7,63}$"},
          "workflow_id": {"type": "string", "pattern": "^wf_[0-9]{8}_[0-9a-f]{8}$"},
          "selected_workflow_id": {"type": "string", "pattern": "^wf_[0-9]{8}_[0-9a-f]{8}$"},
          "current_workflow_id": {"type": "string", "pattern": "^wf_[0-9]{8}_[0-9a-f]{8}$"},
          "selection_scope": {"type": "string"},
          "project_root": {"type": "string", "minLength": 1},
          "server_state_file": {"type": "string", "minLength": 1},
          "host": {"type": "string", "enum": ["127.0.0.1", "localhost"]},
          "port": {"type": "integer", "minimum": 1, "maximum": 65535},
          "url": {"type": "string", "minLength": 1},
          "api_base_url": {"type": "string", "minLength": 1},
          "pid": {"type": "integer", "minimum": 1},
          "started_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"},
          "updated_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"},
          "token_required": {"type": "boolean"},
          "mutating_api_requires_token": {"type": "boolean"},
          "same_origin_required": {"type": "boolean"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
