{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LoopPlane preview result",
  "type": "object",
  "required": ["schema_version", "generated_at", "mode", "next_action", "would_mutate_state"],
  "properties": {
    "schema_version": {"const": "1.5"},
    "generated_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"},
    "mode": {"const": "dry_run"},
    "next_action": {"type": "string"},
    "would_mutate_state": {"type": "boolean"}
  }
}
