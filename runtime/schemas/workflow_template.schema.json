{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LoopPlane workflow template",
  "type": "object",
  "required": ["schema_version", "kind", "id", "version", "title", "inputs", "renders"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "kind": {"const": "loopplane.workflow_template"},
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{1,127}$"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "title": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "inputs": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {"type": "string", "enum": ["string", "integer", "number", "boolean", "array", "object"]},
          "required": {"type": "boolean"},
          "default": true,
          "description": {"type": "string"},
          "enum": {"type": "array"},
          "minimum": {"type": "number"},
          "maximum": {"type": "number"},
          "minLength": {"type": "integer", "minimum": 0},
          "maxLength": {"type": "integer", "minimum": 0},
          "derived": {"type": "string"},
          "locked": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    },
    "renders": {
      "type": "object",
      "minProperties": 1,
      "properties": {
        "project_brief": {"type": "string", "minLength": 1},
        "plan_draft": {"type": "string", "minLength": 1},
        "shared_context": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "locked_sections": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "default_policy": {
      "type": "object",
      "properties": {
        "planner_mode": {"type": "string", "enum": ["deterministic", "bounded_adaptation", "freeform"]},
        "activation_required": {"type": "boolean"},
        "self_expansion": {"type": "string", "enum": ["off", "bounded", "aggressive"]},
        "validation_strictness": {"type": "string", "enum": ["low", "medium", "high"]},
        "final_review": {"type": "boolean"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
