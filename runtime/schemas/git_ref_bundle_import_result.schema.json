{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LoopPlane Git ref bundle import result",
  "type": "object",
  "required": ["schema_version", "generated_at", "status", "ok", "project_root", "input", "git", "repository", "bundle", "import", "checkpoint_log", "safety", "warnings", "errors"],
  "properties": {
    "schema_version": {"const": "loopplane-git-ref-bundle-import-1"},
    "generated_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"},
    "status": {"type": "string"},
    "ok": {"type": "boolean"},
    "project_root": {"type": "string", "minLength": 1},
    "workflow_id": {"type": ["string", "null"]},
    "input": {"type": "string", "minLength": 1},
    "git": {"type": "object", "required": ["available"]},
    "repository": {"type": "object", "required": ["detected", "inside_work_tree"]},
    "bundle": {"type": "object", "required": ["path", "format", "head_count", "importable_ref_count", "ignored_ref_count", "managed_refs_only"]},
    "import": {"type": "object", "required": ["performed", "imported_count", "refs", "managed_refs_only", "non_managed_refs_updated"]},
    "checkpoint_log": {"type": "object", "required": ["path", "record_count"]},
    "safety": {"type": "object", "required": ["no_remote_push", "no_remote_fetch", "remote_operations_performed", "branch_switch_performed", "history_rewritten", "user_history_modified", "user_branch_modified"]},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "errors": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
