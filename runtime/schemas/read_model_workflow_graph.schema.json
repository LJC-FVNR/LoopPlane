{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LoopPlane workflow_graph read model",
  "type": "object",
  "required": ["schema_version", "workflow_id", "generated_at", "source_hashes", "nodes", "edges"],
  "properties": {
    "schema_version": {"const": "1.5"},
    "workflow_id": {"type": "string"},
    "generated_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"},
    "source_hashes": {"type": "object"},
    "nodes": {"type": "array"},
    "edges": {"type": "array"}
  }
}
