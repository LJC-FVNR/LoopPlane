{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LoopPlane workflow preset",
  "type": "object",
  "required": ["schema_version", "kind", "template", "inputs"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "kind": {"const": "loopplane.workflow_preset"},
    "name": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "template": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{1,127}$"},
    "template_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "template_lock": {
      "type": "object",
      "properties": {
        "source": {"type": "string"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "inputs": {"type": "object"},
    "policy": {"type": "object"}
  },
  "additionalProperties": true
}
