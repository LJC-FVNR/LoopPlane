def run_write_brief(args: argparse.Namespace) -> int:
    brief_file = getattr(args, "brief_file", None)
    sources = [
        bool(args.text is not None),
        bool(args.file is not None or brief_file is not None),
        bool(args.stdin),
    ]
    if sum(1 for selected in sources if selected) != 1:
        result = {
            "schema_version": "1.5",
            "ok": False,
            "status": "missing_input" if not any(sources) else "ambiguous_input",
            "project_root": str(Path(args.project or ".").expanduser().resolve()),
            "workflow_id": None,
            "changed": False,
            "errors": ["Use exactly one of --text, --file, or --stdin."],
            "warnings": [],
        }
    else:
        try:
            if args.text is not None:
                content = args.text
                source = "cli --text"
            elif args.file is not None or brief_file is not None:
                input_path = Path(args.file or brief_file).expanduser()
                content = input_path.read_text(encoding="utf-8")
                source = f"cli --file {input_path.as_posix()}"
            else:
                content = sys.stdin.read()
                source = "cli --stdin"
            result = write_project_brief(
                Path(args.project or "."),
                content,
                source=source,
                force=args.force,
            )
        except OSError as error:
            result = {
                "schema_version": "1.5",
                "ok": False,
                "status": "input_read_failed",
                "project_root": str(Path(args.project or ".").expanduser().resolve()),
                "workflow_id": None,
                "changed": False,
                "errors": [f"Unable to read brief input: {error}"],
                "warnings": [],
            }

    if args.json:
        _print_json_result(result, args, compact_lists=True)
    else:
        print(format_write_brief_text(result), end="")
    return write_brief_exit_code(result)


def run_scheduler_command(args: argparse.Namespace) -> int:
    if getattr(args, "dry_run", False):
        result = preview_scheduler(Path(args.project or "."))
        print(json.dumps(result, indent=2, sort_keys=True))
        return preview_exit_code(result)
    project = Path(args.project or ".")
    progress_interval = float(getattr(args, "progress_interval", 30.0))
    max_ticks = 1_000_000 if getattr(args, "until_complete", False) else args.max_ticks
    with _SchedulerProgressReporter(project, interval_seconds=progress_interval):
        result = run_scheduler(
            project,
            max_ticks=max_ticks,
            continue_after_final_verification=bool(getattr(args, "until_complete", False)),
        )
    if args.json:
        payload = scheduler_summary(result) if getattr(args, "summary", False) else result
        print(json.dumps(payload, indent=2, sort_keys=True))
    elif getattr(args, "summary", False):
        print(format_scheduler_summary_text(result), end="")
    else:
        print(format_scheduler_text(result), end="")
    return scheduler_exit_code(result)


class _SchedulerProgressReporter:
    _ACTIVE_STATUSES = {"starting", "running", "pending", "waiting"}
    _DIR_FIELDS = ("task_evidence_run_dir", "role_output_dir", "scheduler_run_dir")
    _SKIP_PROJECT_DIRS = {".loopplane", ".git", ".hg", ".svn", "__pycache__", ".pytest_cache", "node_modules", ".venv", "venv"}

    def __init__(self, project: Path, *, interval_seconds: float, stream: Any | None = None) -> None:
        self.project = project.expanduser().resolve()
        self.interval_seconds = max(0.0, interval_seconds)
        self.stream = stream if stream is not None else sys.stderr
        self._stop = threading.Event()
        self._thread: threading.Thread | None = None
        self._seen_files: set[str] = set()
        self._seen_project_files: set[str] = set()
        self._started_at = time.time()
        self._evidence_since: dict[str, float] = {}

    def __enter__(self) -> "_SchedulerProgressReporter":
        if self.interval_seconds > 0:
            self._thread = threading.Thread(target=self._run, name="loopplane-run-progress", daemon=True)
            self._thread.start()
        return self

    def __exit__(self, exc_type: object, exc: object, tb: object) -> None:
        self._stop.set()
        if self._thread is not None:
            self._thread.join(timeout=min(1.0, max(0.05, self.interval_seconds)))

    def _run(self) -> None:
        while not self._stop.wait(self.interval_seconds):
            try:
                line = self._progress_line()
            except Exception:
                continue
            if line:
                print(line, file=self.stream, flush=True)

    def _progress_line(self) -> str | None:
        lease = self._latest_active_lease()
        if lease is None:
            return None
        new_files = self._new_files(lease)
        parts = [
            "[loopplane run] active",
            f"run_id={_progress_text(lease.get('run_id'))}",
            f"role={_progress_text(lease.get('role'))}",
            f"task={_progress_text(lease.get('task_id'))}",
            f"runner={_progress_text(lease.get('runner_id'))}",
            f"status={_progress_text(lease.get('status'))}",
            f"scheduler_pid={_progress_text(lease.get('scheduler_pid') or lease.get('adapter_pid'))}",
            f"adapter_pid={_progress_text(lease.get('adapter_child_pid'))}",
            f"heartbeat={_progress_text(lease.get('heartbeat_count'))}",
        ]
        if new_files:
            sample = ", ".join(new_files[:6])
            suffix = "" if len(new_files) <= 6 else f", +{len(new_files) - 6} more"
            parts.append(f"new_files={sample}{suffix}")
        project_files = self._recent_project_files()
        if project_files:
            sample = ", ".join(project_files[:6])
            suffix = "" if len(project_files) <= 6 else f", +{len(project_files) - 6} more"
            parts.append(f"project_changes={sample}{suffix}")
        if self._evidence_present(lease):
            parts.append("adapter_phase=awaiting_adapter_exit")
            elapsed = self._adapter_phase_elapsed(lease)
            if elapsed is not None:
                parts.append(f"adapter_phase_elapsed={elapsed}s")
            stdout_tail = _progress_log_tail(_progress_project_path(self.project, lease.get("stdout_path")))
            stderr_tail = _progress_log_tail(_progress_project_path(self.project, lease.get("stderr_path")))
            if stdout_tail:
                parts.append(f"stdout_tail={stdout_tail}")
            if stderr_tail:
                parts.append(f"stderr_tail={stderr_tail}")
        return " ".join(parts)

    def _latest_active_lease(self) -> dict[str, Any] | None:
        context_result = load_scheduler_context(self.project)
        if not context_result.get("ok"):
            return None
        context = context_result.get("context")
        paths = getattr(context, "paths", None)
        runtime_dir = getattr(paths, "runtime_dir", None)
        if not isinstance(runtime_dir, Path):
            return None
        lease_dir = runtime_dir / "active_run_leases"
        if not lease_dir.is_dir():
            return None
        leases: list[tuple[float, dict[str, Any]]] = []
        for path in lease_dir.glob("*.json"):
            lease = _read_progress_json(path)
            if not isinstance(lease, dict):
                continue
            status = str(lease.get("status") or "").strip()
            if status not in self._ACTIVE_STATUSES:
                continue
            try:
                modified = path.stat().st_mtime
            except OSError:
                modified = 0.0
            leases.append((modified, lease))
        if not leases:
            return None
        leases.sort(key=lambda item: item[0], reverse=True)
        return leases[0][1]

    def _new_files(self, lease: Mapping[str, Any]) -> list[str]:
        observed: list[str] = []
        for field in self._DIR_FIELDS:
            directory = _progress_project_path(self.project, lease.get(field))
            if directory is None or not directory.is_dir():
                continue
            for path in sorted(directory.rglob("*")):
                if not path.is_file():
                    continue
                rel = _progress_relative_path(self.project, path)
                if rel in self._seen_files:
                    continue
                self._seen_files.add(rel)
                observed.append(rel)
                if len(observed) >= 20:
                    return observed
        return observed

    def _evidence_present(self, lease: Mapping[str, Any]) -> bool:
        evidence_dir = _progress_project_path(self.project, lease.get("task_evidence_run_dir"))
        if evidence_dir is None or not evidence_dir.is_dir():
            return False
        return any((evidence_dir / name).is_file() for name in ("agent_status.json", "report.md", "commands.sh"))

    def _adapter_phase_elapsed(self, lease: Mapping[str, Any]) -> int | None:
        run_id = str(lease.get("run_id") or "")
        if not run_id:
            return None
        now = time.time()
        self._evidence_since.setdefault(run_id, now)
        return max(0, int(now - self._evidence_since[run_id]))

    def _recent_project_files(self) -> list[str]:
        observed: list[str] = []
        for root, dirs, files in os.walk(self.project):
            dirs[:] = [name for name in dirs if name not in self._SKIP_PROJECT_DIRS]
            for name in sorted(files):
                path = Path(root) / name
                try:
                    stat = path.stat()
                except OSError:
                    continue
                if stat.st_mtime < self._started_at:
                    continue
                rel = _progress_relative_path(self.project, path)
                if rel in self._seen_project_files or rel.startswith(".loopplane/"):
                    continue
                self._seen_project_files.add(rel)
                observed.append(rel)
                if len(observed) >= 20:
                    return observed
        return observed


class _PlanningProgressReporter:
    _ROLE_PROMPTS = {
        "planner": "planner_prompt.md",
        "auditor": "auditor_prompt.md",
    }

    def __init__(
        self,
        project: Path,
        *,
        command: str,
        roles: set[str],
        interval_seconds: float,
        stream: Any | None = None,
    ) -> None:
        self.project = project.expanduser().resolve()
        self.command = command
        self.roles = set(roles)
        self.interval_seconds = max(0.0, interval_seconds)
        self.stream = stream if stream is not None else sys.stderr
        self._stop = threading.Event()
        self._thread: threading.Thread | None = None
        self._seen_files: set[str] = set()
        self._known_run_dirs: set[Path] = set()

    def __enter__(self) -> "_PlanningProgressReporter":
        if self.interval_seconds > 0:
            self._known_run_dirs = set(self._planning_run_dirs())
            self._thread = threading.Thread(target=self._run, name=f"loopplane-{self.command}-progress", daemon=True)
            self._thread.start()
        return self

    def __exit__(self, exc_type: object, exc: object, tb: object) -> None:
        self._stop.set()
        if self._thread is not None:
            self._thread.join(timeout=min(1.0, max(0.05, self.interval_seconds)))

    def _run(self) -> None:
        while not self._stop.wait(self.interval_seconds):
            try:
                line = self._progress_line()
            except Exception:
                continue
            if line:
                print(line, file=self.stream, flush=True)

    def _progress_line(self) -> str | None:
        run = self._latest_active_run()
        if run is None:
            return None
        run_dir, role, adapter_input = run
        new_files = self._new_files(run_dir)
        parts = [
            f"[loopplane {self.command}] active",
            f"run_id={run_dir.name}",
            f"role={role}",
            f"runner={_progress_text(adapter_input.get('runner_id') if isinstance(adapter_input, Mapping) else None)}",
            f"run_dir={_progress_relative_path(self.project, run_dir)}",
        ]
        if new_files:
            sample = ", ".join(new_files[:6])
            suffix = "" if len(new_files) <= 6 else f", +{len(new_files) - 6} more"
            parts.append(f"new_files={sample}{suffix}")
        stdout_tail = _progress_log_tail(run_dir / "stdout.log")
        stderr_tail = _progress_log_tail(run_dir / "stderr.log")
        if stdout_tail:
            parts.append(f"stdout_tail={stdout_tail}")
        if stderr_tail:
            parts.append(f"stderr_tail={stderr_tail}")
        return " ".join(parts)

    def _planning_run_dirs(self) -> list[Path]:
        runs_dir = self.project / ".loopplane" / "planning" / "runs"
        if not runs_dir.is_dir():
            return []
        return sorted((path for path in runs_dir.iterdir() if path.is_dir()), key=lambda path: path.name)

    def _latest_active_run(self) -> tuple[Path, str, Mapping[str, Any] | None] | None:
        candidates: list[tuple[float, Path, str, Mapping[str, Any] | None]] = []
        for run_dir in self._planning_run_dirs():
            if run_dir in self._known_run_dirs:
                continue
            role = self._run_role(run_dir)
            if role not in self.roles:
                continue
            if (run_dir / "node_summary.json").is_file():
                continue
            adapter_input = _read_progress_json(run_dir / "adapter_input.json")
            try:
                modified = max((path.stat().st_mtime for path in run_dir.rglob("*") if path.is_file()), default=run_dir.stat().st_mtime)
            except OSError:
                modified = 0.0
            candidates.append((modified, run_dir, role, adapter_input if isinstance(adapter_input, Mapping) else None))
        if not candidates:
            return None
        candidates.sort(key=lambda item: item[0], reverse=True)
        _modified, run_dir, role, adapter_input = candidates[0]
        return run_dir, role, adapter_input

    def _run_role(self, run_dir: Path) -> str:
        adapter_input = _read_progress_json(run_dir / "adapter_input.json")
        if isinstance(adapter_input, Mapping):
            role = str(adapter_input.get("role") or "").strip()
            if role:
                return role
        for role, prompt_name in self._ROLE_PROMPTS.items():
            if (run_dir / prompt_name).is_file():
                return role
        return "planning"

    def _new_files(self, run_dir: Path) -> list[str]:
        observed: list[str] = []
        for path in sorted(run_dir.rglob("*")):
            if not path.is_file():
                continue
            rel = _progress_relative_path(self.project, path)
            if rel in self._seen_files:
                continue
            self._seen_files.add(rel)
            observed.append(rel)
            if len(observed) >= 20:
                break
        return observed


def _read_progress_json(path: Path) -> object | None:
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return None


def _progress_project_path(project: Path, value: object) -> Path | None:
    if not isinstance(value, str) or not value.strip():
        return None
    path = Path(value)
    if path.is_absolute():
        return path
    return project / path


def _progress_relative_path(project: Path, path: Path) -> str:
    try:
        return path.resolve().relative_to(project).as_posix()
    except ValueError:
        return path.as_posix()


def _progress_log_tail(path: Path | None, *, limit: int = 180) -> str:
    if path is None or not path.is_file():
        return ""
    try:
        text = path.read_text(encoding="utf-8", errors="replace")
    except OSError:
        return ""
    text = " ".join(text.strip().split())
    if not text:
        return ""
    if len(text) <= limit:
        return text
    return text[-limit:].lstrip()


def _progress_text(value: object) -> str:
    if value is None or value == "":
        return "-"
    return str(value)


def run_preview(args: argparse.Namespace) -> int:
    result = preview_scheduler(Path(args.project or "."), write=args.write)
    if args.json:
        print(json.dumps(result, indent=2, sort_keys=True))
    else:
        print(format_preview_text(result), end="")
    return preview_exit_code(result)


def run_health(args: argparse.Namespace) -> int:
    if getattr(args, "all", False) and getattr(args, "workflow", None):
        result = {
            "schema_version": "1.6",
            "ok": False,
            "status": "invalid_arguments",
            "project_root": str(Path(args.project or ".").expanduser().resolve()),
            "errors": ["--all and --workflow cannot be combined."],
            "workflow_results": [],
        }
        if args.json:
            print(json.dumps(result, indent=2, sort_keys=True))
        else:
            print("loopplane health: invalid_arguments")
            print("error: --all and --workflow cannot be combined.")
        return EXIT_INVALID_CONFIG
    if getattr(args, "all", False):
        result = _run_health_all(Path(args.project or "."), strict=args.strict, write=args.write)
        if args.json:
            print(json.dumps(result, indent=2, sort_keys=True))
        else:
            print(_format_health_all_text(result), end="")
        return _health_all_exit_code(result)

    result = run_health_probe(
        Path(args.project or "."),
        workflow_id=getattr(args, "workflow", None),
        strict=args.strict,
        write=args.write,
    )
    if args.json:
        print(json.dumps(result, indent=2, sort_keys=True))
    else:
        print(format_health_text(result), end="")
    return health_exit_code(result)


def _run_health_all(project: Path, *, strict: bool, write: bool) -> dict[str, Any]:
    project = project.expanduser().resolve()
    listed = list_workflows(project)
    if not listed.get("ok"):
        return {
            "schema_version": "1.6",
            "ok": False,
            "status": "workflow_list_failed",
            "project_root": project.as_posix(),
            "strict": strict,
            "write": write,
            "workflow_count": 0,
            "workflow_results": [],
            "errors": list(listed.get("errors") or ["Unable to list workflow histories."]),
            "warnings": list(listed.get("warnings") or []),
        }
    workflow_results = []
    for workflow in listed.get("workflows") or []:
        if not isinstance(workflow, Mapping):
            continue
        workflow_id = str(workflow.get("workflow_id") or "").strip()
        if not workflow_id:
            continue
        health = run_health_probe(project, workflow_id=workflow_id, strict=strict, write=write)
        workflow_results.append(
            {
                "workflow_id": workflow_id,
                "name": workflow.get("name"),
                "current": bool(workflow.get("current")),
                "status": health.get("status"),
                "ok": health.get("ok"),
                "requires_attention": list(health.get("requires_attention") or []),
                "health": health,
            }
        )
    ok = all(bool(item.get("ok")) for item in workflow_results) if workflow_results else False
    return {
        "schema_version": "1.6",
        "ok": ok,
        "status": "healthy" if ok else "requires_attention",
        "project_root": project.as_posix(),
        "strict": strict,
        "write": write,
        "workspace_id": listed.get("workspace_id"),
        "current_workflow_id": listed.get("current_workflow_id"),
        "workflow_count": len(workflow_results),
        "workflow_results": workflow_results,
        "errors": [],
        "warnings": list(listed.get("warnings") or []),
    }


def _format_health_all_text(result: Mapping[str, Any]) -> str:
    lines = [
        f"loopplane health --all: {result.get('status', 'unknown')}",
        f"project: {result.get('project_root') or 'unknown'}",
        f"workspace_id: {result.get('workspace_id') or 'unknown'}",
        f"current_workflow_id: {result.get('current_workflow_id') or 'unknown'}",
        f"strict: {str(bool(result.get('strict'))).lower()}",
    ]
    errors = result.get("errors")
    if isinstance(errors, Sequence) and errors and not isinstance(errors, (str, bytes)):
        lines.append("errors:")
        lines.extend(f"  - {error}" for error in errors)
    workflow_results = result.get("workflow_results")
    if isinstance(workflow_results, Sequence) and not isinstance(workflow_results, (str, bytes)):
        lines.append("workflows:")
        for item in workflow_results:
            if not isinstance(item, Mapping):
                continue
            current = " current" if item.get("current") else ""
            lines.append(
                "  - "
                f"{item.get('workflow_id') or 'unknown'}{current}: "
                f"{item.get('status') or 'unknown'} "
                f"ok={str(bool(item.get('ok'))).lower()} "
                f"name={item.get('name') or 'unknown'}"
            )
            attention = item.get("requires_attention")
            if isinstance(attention, Sequence) and attention and not isinstance(attention, (str, bytes)):
                lines.append(f"    requires_attention: {len(attention)} item(s)")
    warnings = result.get("warnings")
    if isinstance(warnings, Sequence) and warnings and not isinstance(warnings, (str, bytes)):
        lines.append("warnings:")
        lines.extend(f"  - {warning}" for warning in warnings)
    return "\n".join(lines) + "\n"


def _health_all_exit_code(result: Mapping[str, Any]) -> int:
    if not result.get("ok"):
        return EXIT_HEALTH_FAILURE
    return 0


