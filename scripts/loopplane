    restore.add_argument("workflow_id", metavar="<workflow_id>", help="Workflow id to restore.")
    _add_workflow_common_options(restore)
    restore.set_defaults(handler=run_workflow_restore, command_path=("workflow", "restore"))

    fork = workflow_subparsers.add_parser(
