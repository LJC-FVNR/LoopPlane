def run_verify_objectives(args: argparse.Namespace) -> int:
    result = run_objective_verifier_once(
        Path(args.project or "."),
        scope=args.scope,
        phase_id=args.phase_id,
        owner="cli",
        force=args.force,
    )
    if args.json:
        print(json.dumps(result, indent=2, sort_keys=True))
    else:
        print(f"loopplane verify-objectives: {result.get('status', 'unknown')}")
        execution = result.get("execution_result")
        if isinstance(execution, Mapping):
            print(f"ok: {execution.get('ok')}")
            if execution.get("objective_verification_report"):
                print(f"objective_verification_report: {execution.get('objective_verification_report')}")
        errors = result.get("errors")
        if isinstance(errors, Sequence) and not isinstance(errors, (str, bytes)):
            for error in errors:
                print(f"error: {error}")
    return 0 if result.get("ok") else EXIT_GENERIC_FAILURE


