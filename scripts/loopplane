def run_background_start(args: argparse.Namespace) -> int:
    try:
        env = _parse_background_env(getattr(args, "env", None) or [])
        result = start_background_job(
            Path(args.project or "."),
            command=list(getattr(args, "command", None) or []),
            shell=bool(getattr(args, "shell", False)),
            cwd=Path(args.cwd) if getattr(args, "cwd", None) else None,
            env=env,
            job_id=getattr(args, "job_id", None),
            label=getattr(args, "label", None),
            task_id=getattr(args, "task", None),
            run_id=getattr(args, "run", None),
            workflow_id=getattr(args, "workflow", None),
            timeout_seconds=getattr(args, "timeout_seconds", None),
            wake_next_agent_when=getattr(args, "wake_next_agent_when", None),
            watchdog_interval_seconds=getattr(args, "watchdog_interval_seconds", None),
            watchdog_runner=getattr(args, "watchdog_runner", None),
            watchdog_question=getattr(args, "watchdog_question", None),
        )
    except ValueError as error:
        result = _control_command_failure(args.project, f"Invalid background job request: {error}")
        result["status"] = "invalid_background_job_request"
        result["exit_code"] = EXIT_INVALID_CONFIG
    if args.json:
        print(json.dumps(result, indent=2, sort_keys=True))
    else:
        print(format_background_text(result), end="")
    return background_exit_code(result)


