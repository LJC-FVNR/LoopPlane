def _control_command_failure(project: str | None, message: str) -> dict[str, Any]:
    return {
        "schema_version": "1.5",
        "ok": False,
        "status": "failed",
        "project_root": str(Path(project or ".").expanduser()),
        "workflow_id": None,
        "message": message,
        "errors": [message],
        "warnings": [],
    }


def _waiting_config_command_failure(project: str | None, message: str) -> dict[str, Any]:
    project_path = Path(project or ".").expanduser()
    workflow_path = project_path / ".loopplane" / "config" / "workflow.json"
    problem = {
        "code": "workflow_config_unavailable",
        "message": message,
        "recoverable": True,
        "path": workflow_path.as_posix(),
        "recovery_actions": [
            "Restore .loopplane/config/workflow.json from a checkpoint or backup.",
            "Run loopplane init --project <project> --brief <brief> if this directory has not been initialized.",
        ],
    }
    return {
        "schema_version": "1.5",
        "ok": False,
        "status": "waiting_config",
        "project_root": str(project_path),
        "workflow_id": None,
        "message": message,
        "configuration_problems": [problem],
        "recovery_actions": list(problem["recovery_actions"]),
        "errors": [message],
        "warnings": [],
    }


