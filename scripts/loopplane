def format_self_expansion_text(result: Mapping[str, Any]) -> str:
    lines = [
        f"loopplane self-expansion: {result.get('status', 'unknown')}",
        f"workflow_id: {result.get('workflow_id') or 'unknown'}",
    ]
    if result.get("registry_path"):
        lines.append(f"registry: {result.get('registry_path')}")
    if result.get("cycle") is not None:
        lines.append(f"cycle: {result.get('cycle')}")
    if result.get("proposal_count") is not None:
        lines.append(f"proposals: {result.get('proposal_count')}")
    if result.get("proposal_id"):
        lines.append(f"proposal_id: {result.get('proposal_id')}")
    if result.get("resolution_strategy"):
        lines.append(f"resolution_strategy: {result.get('resolution_strategy')}")
    if result.get("added_task_ids"):
        lines.append("added_task_ids:")
        lines.extend(f"  - {task_id}" for task_id in result.get("added_task_ids") or [])
    latest = result.get("latest_proposal")
    if isinstance(latest, Mapping):
        lines.append(f"latest_proposal: {latest.get('proposal_id') or 'unknown'} ({latest.get('status') or 'unknown'})")
    policy = result.get("policy")
    if isinstance(policy, Mapping):
        lines.append(f"enabled: {policy.get('enabled')}")
        lines.append(f"max_cycles: {policy.get('max_cycles')}")
        lines.append(f"max_tasks_per_cycle: {policy.get('max_tasks_per_cycle')}")
    for key in ("errors", "warnings"):
        values = result.get(key)
        if isinstance(values, Sequence) and values and not isinstance(values, (str, bytes)):
            lines.append(f"{key}:")
            lines.extend(f"  - {value}" for value in values)
    return "\n".join(lines) + "\n"


def run_migrate(args: argparse.Namespace) -> int:
    if getattr(args, "split_run_summaries", False):
        result = split_legacy_run_summaries(
            Path(args.project or "."),
            workflow_id=getattr(args, "workflow", None),
            dry_run=args.dry_run,
        )
        if args.json:
            print(json.dumps(result, indent=2, sort_keys=True))
        else:
            print(format_migration_text(result), end="")
        return 0 if result.get("ok") else EXIT_GENERIC_FAILURE
    if getattr(args, "compact_event_payloads", False):
        result = compact_historical_event_payloads(
            Path(args.project or "."),
            workflow_id=getattr(args, "workflow", None),
            dry_run=args.dry_run,
            threshold_bytes=getattr(args, "payload_threshold_bytes", None),
            compact_all_events=bool(getattr(args, "compact_all_events", False)),
        )
        if args.json:
            print(json.dumps(result, indent=2, sort_keys=True))
        else:
            print(format_migration_text(result), end="")
        return 0 if result.get("ok") else EXIT_GENERIC_FAILURE
    if getattr(args, "repair_event_manifest", False):
        result = repair_event_segment_manifest(
            Path(args.project or "."),
            workflow_id=getattr(args, "workflow", None),
            dry_run=args.dry_run,
        )
        if args.json:
            print(json.dumps(result, indent=2, sort_keys=True))
        else:
            print(format_migration_text(result), end="")
        return 0 if result.get("ok") else EXIT_GENERIC_FAILURE
    result = migrate_project(Path(args.project or "."), dry_run=args.dry_run)
    if args.json:
        print(json.dumps(result, indent=2, sort_keys=True))
    else:
        print(format_migration_text(result), end="")
    return migration_exit_code(result)


