def run_skill_install(args: argparse.Namespace) -> int:
    if not args.target:
        print("loopplane skill install: --target is required.")
        return EXIT_INVALID_CONFIG
    if args.no_agent_skill_projection and (args.agent_style or args.all_agent_skills):
        print("loopplane skill install: --no-agent-skill-projection cannot be combined with --agent-style or --all-agent-skills.")
        return EXIT_INVALID_CONFIG
    if args.all_agent_skills and args.agent_style:
        print("loopplane skill install: --all-agent-skills cannot be combined with --agent-style.")
        return EXIT_INVALID_CONFIG
    result = install_skill_project(
        Path(args.target),
        agent_styles=None if args.all_agent_skills else args.agent_style,
        project_agent_skills=not args.no_agent_skill_projection,
    )
    if args.json:
        _print_json_result(result, args, compact_lists=True)
    else:
        print(format_skill_install_text(result), end="")
    return skill_install_exit_code(result)


