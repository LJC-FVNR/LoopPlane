def _parse_template_set_values(values: Sequence[str]) -> dict[str, Any]:
    parsed: dict[str, Any] = {}
    for value in values:
        if "=" not in value:
            raise SystemExit(f"--set expects key=value, got {value!r}")
        key, raw = value.split("=", 1)
        key = key.strip()
        if not key:
            raise SystemExit("--set key must be non-empty")
        parsed[key] = raw
    return parsed


def run_workflow_create(args: argparse.Namespace) -> int:
    template_id = getattr(args, "template", None)
    preset = getattr(args, "preset", None)
    if template_id or preset:
        overrides = _parse_template_set_values(getattr(args, "set_values", None) or [])
        if getattr(args, "brief", None):
            result = {
                "schema_version": "1.6",
                "ok": False,
                "status": "template_brief_unsupported",
                "errors": ["--brief is only supported for free-form workflow creation."],
                "warnings": [],
                "recovery_actions": ["Use --set <input=value> for template workflow inputs, or omit --template/--preset."],
            }
        else:
            result = create_workflow_from_template(
                Path(args.project or "."),
                template_id=template_id,
                preset_path=preset,
                overrides=overrides,
                template_dir=getattr(args, "template_dir", None),
                dry_run=bool(getattr(args, "dry_run", False)),
            )
    else:
        if not str(getattr(args, "brief", "") or "").strip():
            result = {
                "schema_version": "1.6",
                "ok": False,
                "status": "invalid_brief",
                "errors": ["--brief must be a non-empty string unless --template or --preset is supplied."],
                "warnings": [],
                "recovery_actions": ["Pass --brief <text> for free-form workflow creation or use --template/--preset."],
            }
        else:
            result = create_workflow(Path(args.project or "."), str(args.brief))
    if args.json:
        print(json.dumps(result, indent=2, sort_keys=True))
    else:
        print(format_workflow_create_text(result), end="")
    return workflow_create_exit_code(result)


