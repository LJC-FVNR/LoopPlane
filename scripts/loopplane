def run_dashboard(args: argparse.Namespace) -> int:
    if getattr(args, "dashboard_action", None) == "list":
        result = list_dashboard_servers(Path(args.project or "."))
        if args.json:
            print(json.dumps(result, indent=2, sort_keys=True))
        else:
            print(format_dashboard_list_text(result), end="")
        return dashboard_list_exit_code(result)
    if getattr(args, "dashboard_action", None) in {"cleanup", "stop"}:
        result = cleanup_dashboard_servers(
            Path(args.project or "."),
            stop=getattr(args, "dashboard_action", None) == "stop",
            terminate_orphans=bool(getattr(args, "terminate_orphans", False)),
        )
        if args.json:
            print(json.dumps(result, indent=2, sort_keys=True))
        else:
            print(format_dashboard_cleanup_text(result), end="")
        return dashboard_list_exit_code(result)
    if getattr(args, "dashboard_action", None) == "benchmark":
        result = benchmark_dashboard_loading(
            Path(args.project or "."),
            workflow_id=args.workflow,
            max_dashboard_events=getattr(args, "max_dashboard_events", None),
            iterations=getattr(args, "iterations", 3),
            warmups=getattr(args, "warmups", 1),
            include_no_write_rebuild=bool(getattr(args, "include_no_write_rebuild", False)),
        )
        if args.json:
            print(json.dumps(result, indent=2, sort_keys=True))
        else:
            print(format_dashboard_benchmark_text(result), end="")
        return 0 if result.get("ok") else EXIT_GENERIC_FAILURE

    if args.port is not None:
        try:
            server, result = create_dashboard_server(
                Path(args.project or "."),
                port=args.port,
                host=args.host,
                rebuild_read_models_first=args.rebuild_read_models,
                workflow_id=args.workflow,
                max_dashboard_events=getattr(args, "max_dashboard_events", None),
            )
        except DashboardServerError as error:
            result = error.result
            if args.json:
                print(json.dumps(result, indent=2, sort_keys=True))
            else:
                print(format_dashboard_text(result), end="")
            return dashboard_exit_code(result)
        except (OSError, ValueError, json.JSONDecodeError, WorkflowPathError) as error:
            result = {
                "schema_version": "1.5",
                "ok": False,
                "status": "failed",
                "server_mode": True,
                "project_root": str(Path(args.project or ".").expanduser().resolve()),
                "workflow_id": args.workflow,
                "errors": [str(error)],
                "warnings": [],
            }
            if args.json:
                print(json.dumps(result, indent=2, sort_keys=True))
            else:
                print(format_dashboard_text(result), end="")
            return dashboard_exit_code(result)

        if args.json:
            print(json.dumps(result, sort_keys=True), flush=True)
            _close_stdout_for_foreground_json_server()
        else:
            print(format_dashboard_text(result), end="", flush=True)
            print("Press Ctrl-C to stop.", flush=True)
        try:
            server.serve_forever()
        except KeyboardInterrupt:
            pass
        finally:
            server.server_close()
        return 0

    result = render_static_dashboard(
        Path(args.project or "."),
        output_dir=Path(args.output) if args.output else None,
        rebuild_read_models_first=args.rebuild_read_models,
        workflow_id=args.workflow,
        max_dashboard_events=getattr(args, "max_dashboard_events", None),
        embed_workflow_snapshots=bool(getattr(args, "embed_workflow_snapshots", False)),
    )
    if args.json:
        print(json.dumps(result, indent=2, sort_keys=True))
    else:
        print(format_dashboard_text(result), end="")
    return dashboard_exit_code(result)


def _close_stdout_for_foreground_json_server() -> None:
    try:
        sys.stdout.flush()
        os.close(sys.stdout.fileno())
        sys.stdout = open(os.devnull, "w", encoding="utf-8")
    except (OSError, ValueError):
        pass


def run_control_request(args: argparse.Namespace) -> int:
    payload: dict[str, Any] = {}
    control_type = str(args.control_type)
    if control_type == "start":
        payload["detach"] = bool(getattr(args, "detach", False))
    if control_type == "migrate":
        payload["mode"] = "schema_check"
    try:
        result = record_control_request(
            Path(args.project or "."),
            control_type,
            source="cli",
            payload=payload,
        )
    except (OSError, json.JSONDecodeError, WorkflowPathError, WorkflowLifecycleError) as error:
        result = _control_command_failure(args.project, f"Unable to record control request: {error}")
    result = _maybe_clear_verified_runner_availability_holds(args, result)
    if args.json:
        print(json.dumps(result, indent=2, sort_keys=True))
    else:
        print(format_control_request_text(result), end="")
    return control_exit_code(result)


def run_start(args: argparse.Namespace) -> int:
    if getattr(args, "detach", False):
        try:
            result = start_detached_scheduler(Path(args.project or "."))
        except (OSError, json.JSONDecodeError, WorkflowPathError) as error:
            result = _waiting_config_command_failure(args.project, f"Unable to start detached scheduler: {error}")
        if args.json:
            print(json.dumps(result, indent=2, sort_keys=True))
        else:
            print(format_detached_start_text(result), end="")
        return detached_start_exit_code(result)
    return run_control_request(args)


def run_resume(args: argparse.Namespace) -> int:
    if getattr(args, "foreground_owner", False):
        # A Slurm/systemd controller that immediately enters
        # ``runtime.detached supervisor`` must remain the sole supervisor
        # owner.  Record the durable resume boundary without also spawning a
        # detached process that would race the external foreground owner.
        return run_control_request(args)
    try:
        result = resume_detached_scheduler(Path(args.project or "."))
    except (OSError, json.JSONDecodeError, WorkflowPathError) as error:
        result = _waiting_config_command_failure(args.project, f"Unable to resume detached scheduler: {error}")
    result = _maybe_clear_verified_runner_availability_holds(args, result)
    if args.json:
        print(json.dumps(result, indent=2, sort_keys=True))
    else:
        print(format_control_request_text(result), end="")
    return control_exit_code(result)


def _maybe_clear_verified_runner_availability_holds(
    args: argparse.Namespace,
    result: dict[str, Any],
) -> dict[str, Any]:
    if not bool(getattr(args, "clear_runner_availability_holds", False)) or result.get("ok") is not True:
        return result
    request = result.get("request")
    request_id = str(request.get("request_id") or "") if isinstance(request, Mapping) else ""
    clear_result = clear_verified_runner_availability_holds(
        Path(args.project or "."),
        request_id=request_id,
        control_type=str(getattr(args, "control_type", "resume")),
        clear_reason="CLI caller independently verified live runner availability before resume",
    )
    updated = dict(result)
    updated["runner_availability_clear"] = clear_result
    if clear_result.get("ok") is not True:
        updated["ok"] = False
        updated["status"] = "runner_availability_clear_failed"
        updated["errors"] = [
            *list(updated.get("errors") or []),
            str(clear_result.get("message") or "Unable to clear verified runner availability holds."),
        ]
    return updated


def run_status(args: argparse.Namespace) -> int:
    try:
