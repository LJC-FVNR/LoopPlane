    _add_workflow_common_options(fork)
    fork.set_defaults(handler=run_workflow_fork, command_path=("workflow", "fork"))


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="loopplane",
        description="LoopPlane command-line interface.",
        epilog=COMMAND_GROUPS,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    subparsers = parser.add_subparsers(
        dest="command",
        metavar="<command>",
        title="commands",
    )
    parser.set_defaults(handler=show_help, help_parser=parser)

    add_skill_commands(subparsers)
    add_agent_runner_commands(subparsers)
    add_planning_commands(subparsers)
    add_execution_commands(subparsers)
    add_background_commands(subparsers)
    add_migration_commands(subparsers)
    add_dashboard_and_inspection_commands(subparsers)
    add_self_expansion_commands(subparsers)
    add_version_control_commands(subparsers)
    add_workspace_commands(subparsers)
    add_template_commands(subparsers)
    add_workflow_commands(subparsers)

    return parser


def _normalize_legacy_change_request_args(argv: Sequence[str] | None) -> list[str] | None:
    args = list(argv) if argv is not None else None
    parse_args = list(sys.argv[1:] if args is None else args)
    if not parse_args or parse_args[0] != "change-request":
        return args
    if len(parse_args) == 1 or any(token in {"-h", "--help"} for token in parse_args[1:]):
        return args
    subcommands = {"submit", "review", "apply", "status"}
    if any(token in subcommands for token in parse_args[1:]):
        return args
    normalized = ["change-request", "submit", *parse_args[1:]]
    return normalized


def _normalize_configure_agent_args(argv: Sequence[str] | None) -> list[str] | None:
    args = list(argv) if argv is not None else None
    parse_args = list(sys.argv[1:] if args is None else args)
    if not parse_args or parse_args[0] != "configure-agent":
        return args
    normalized: list[str] = []
    index = 0
    changed = False
    while index < len(parse_args):
        token = parse_args[index]
        if token == "--arg" and index + 1 < len(parse_args):
            value = parse_args[index + 1]
            if value.startswith("-") and value != "--":
                normalized.append(f"--arg={value}")
                index += 2
                changed = True
                continue
        normalized.append(token)
        index += 1
    return normalized if changed else args


def _normalize_cli_args(argv: Sequence[str] | None) -> list[str] | None:
    normalized = _normalize_legacy_change_request_args(argv)
    return _normalize_configure_agent_args(normalized if normalized is not None else argv)


def _auto_dashboard_after_command(args: argparse.Namespace, exit_code: int) -> None:
    if exit_code != 0 or not _auto_dashboard_enabled():
        return
    command_path = tuple(getattr(args, "command_path", ()) or ())
    if not command_path or command_path[0] == "dashboard":
        return
    if getattr(args, "dry_run", False):
        return
    if _auto_dashboard_suppressed_for_command(command_path):
        return
    project_value = _auto_dashboard_project_value(args, command_path)
    if not project_value:
        return
    project = Path(project_value).expanduser().resolve()
    if not _looks_like_loopplane_workspace(project):
        return
    try:
        listing = list_dashboard_servers(project)
    except Exception:
        return
    if listing.get("ok") is True:
        current_workflow_id = str(listing.get("current_workflow_id") or "")
        alive_servers = [
            server
            for server in listing.get("dashboard_servers") or []
            if isinstance(server, Mapping) and server.get("liveness") == "alive" and server.get("stale") is not True
        ]
        if alive_servers:
            preferred = next(
                (
                    server
                    for server in alive_servers
                    if current_workflow_id and _server_workflow_id(server) == current_workflow_id
                ),
                alive_servers[0],
            )
            _write_auto_dashboard_access_link(project, preferred, workflow_id=current_workflow_id)
            return
    _spawn_auto_dashboard(project)


def _auto_dashboard_enabled() -> bool:
    value = os.environ.get("LOOPPLANE_AUTO_DASHBOARD")
    if value is not None:
        return value.strip().lower() not in AUTO_DASHBOARD_DISABLED_VALUES
    if os.environ.get("LOOPPLANE_DASHBOARD_CHILD"):
        return False
    if os.environ.get("PYTEST_CURRENT_TEST"):
        return False
    if not sys.stdout.isatty() or not sys.stderr.isatty():
        return False
    return True


def _auto_dashboard_suppressed_for_command(command_path: tuple[str, ...]) -> bool:
    if command_path in {
        ("ask",),
        ("doctor-agent",),
        ("health",),
        ("logs",),
        ("preview",),
        ("status",),
        ("workspace", "list"),
        ("workspace", "scan"),
        ("workspace", "show"),
        ("workflow", "current"),
        ("workflow", "list"),
        ("workflow", "show"),
        ("workflow", "status"),
    }:
        return True
    if command_path and command_path[0] == "vc":
        return True
    return False


def _auto_dashboard_project_value(args: argparse.Namespace, command_path: tuple[str, ...]) -> str | None:
    if command_path == ("import",):
        return str(getattr(args, "target", "") or "") or None
    if command_path in {("skill", "install"), ("skill", "update")}:
        return str(getattr(args, "target", "") or "") or None
    if command_path in {("skill", "doctor"), ("skill", "pack"), ("workspace", "list"), ("workspace", "scan"), ("workspace", "unregister")}:
        return None
    return str(getattr(args, "project", None) or ".")


def _looks_like_loopplane_workspace(project: Path) -> bool:
    markers = (
        project / ".loopplane" / "config" / "workflow.json",
        project / ".loopplane" / "current_workflow.json",
        project / ".loopplane" / "workspace.json",
    )
    return any(path.exists() for path in markers)


def _server_workflow_id(server: Mapping[str, Any]) -> str:
    return str(server.get("workflow_id") or server.get("selected_workflow_id") or "").strip()


def _write_auto_dashboard_access_link(project: Path, server: Mapping[str, Any], *, workflow_id: str = "") -> None:
    url = str(server.get("url") or "").strip()
    if not url:
        return
    token = ""
    if server.get("token_required"):
        token_file = str(server.get("token_file") or "").strip()
        if token_file:
            try:
                token = (project / token_file).read_text(encoding="utf-8").strip()
            except OSError:
                token = ""
    url = _append_auto_dashboard_query_params(
        url,
        [
            ("token", token),
            ("workflow", workflow_id),
        ],
    )
    path = project / "LOOPPLANE_DASHBOARD.url"
    try:
        path.write_text(f"[InternetShortcut]\nURL={url}\n", encoding="utf-8")
        try:
            os.chmod(path, 0o600)
        except OSError:
            pass
    except OSError:
        return


def _append_auto_dashboard_query_params(url: str, params: Sequence[tuple[str, str]]) -> str:
    next_url = url
    for key, value in params:
        text = str(value or "").strip()
        if not text:
            continue
        separator = "&" if "?" in next_url else "?"
        next_url = f"{next_url}{separator}{quote(str(key), safe='')}={quote(text, safe='')}"
    return next_url


def _spawn_auto_dashboard(project: Path) -> None:
    runtime_dir = project / ".loopplane" / "runtime"
    try:
        runtime_dir.mkdir(parents=True, exist_ok=True)
    except OSError:
        return
    env = os.environ.copy()
    env["LOOPPLANE_DASHBOARD_CHILD"] = "1"
    env["LOOPPLANE_AUTO_DASHBOARD"] = "0"
    command = [
        sys.executable,
        str(Path(__file__).resolve()),
        "dashboard",
        "--project",
        project.as_posix(),
        "--port",
        "auto",
        "--json",
    ]
    stderr_path = runtime_dir / "dashboard_auto_start.log"
    try:
        stderr_handle = stderr_path.open("ab")
    except OSError:
        stderr_handle = subprocess.DEVNULL  # type: ignore[assignment]
    try:
        process = subprocess.Popen(
            command,
            cwd=project,
            env=env,
            stdin=subprocess.DEVNULL,
            stdout=subprocess.PIPE,
            stderr=stderr_handle,
            text=True,
            start_new_session=True,
        )
    except OSError:
        if hasattr(stderr_handle, "close"):
            stderr_handle.close()
        return
    finally:
        if hasattr(stderr_handle, "close"):
            stderr_handle.close()
    startup = _read_auto_dashboard_startup(process)
    if startup.get("ok") is True and isinstance(startup, Mapping):
        workflow_id = str(startup.get("selected_workflow_id") or startup.get("workflow_id") or "").strip()
        _write_auto_dashboard_access_link(project, startup, workflow_id=workflow_id)
    if process.stdout is not None:
        try:
            process.stdout.close()
        except OSError:
            pass


def _read_auto_dashboard_startup(process: subprocess.Popen[str]) -> dict[str, Any]:
    if process.stdout is None:
        return {}
    deadline = time.monotonic() + 5.0
    line = ""
    while time.monotonic() < deadline:
        timeout = max(0.0, min(0.2, deadline - time.monotonic()))
        try:
            readable, _, _ = select.select([process.stdout], [], [], timeout)
        except (OSError, ValueError):
            break
        if readable:
            line = process.stdout.readline()
            break
        if process.poll() is not None:
            line = process.stdout.readline()
            break
    if not line:
        return {}
    try:
        payload = json.loads(line)
    except json.JSONDecodeError:
        return {}
    return dict(payload) if isinstance(payload, Mapping) else {}


def main(argv: Sequence[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(_normalize_cli_args(argv))
    nested_guard = _nested_workspace_preflight(args)
    if nested_guard is not None:
        if getattr(args, "json", False):
            print(json.dumps(nested_guard, indent=2, sort_keys=True))
        else:
            print(_format_nested_workspace_preflight_text(nested_guard), end="")
        return EXIT_SECURITY_POLICY_VIOLATION
    exit_code = args.handler(args)
    _auto_dashboard_after_command(args, exit_code)
    return exit_code


if __name__ == "__main__":
    raise SystemExit(main())
