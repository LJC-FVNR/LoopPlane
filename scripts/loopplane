def format_approval_status_text(result: Mapping[str, Any]) -> str:
    lines = [
        f"loopplane approvals: {result.get('status', 'unknown')}",
        f"workflow_id: {result.get('workflow_id') or 'unknown'}",
    ]
    policy = result.get("approval_policy")
    if isinstance(policy, dict):
        lines.append(f"interactive_approval_enabled: {str(bool(policy.get('enabled'))).lower()}")
        if not policy.get("enabled"):
            lines.append(f"disabled_policy: {policy.get('default_action_when_disabled') or 'block_or_defer'}")
    approvals = result.get("approvals")
    if isinstance(approvals, list) and approvals:
        lines.append("approvals:")
        for approval in approvals:
            if not isinstance(approval, dict):
                continue
            lines.append(
                "  - "
                f"{approval.get('approval_id') or approval.get('request_id')}: "
                f"{approval.get('status', 'unknown')} "
                f"{approval.get('type', '')} "
                f"{approval.get('task_id', '')}".rstrip()
            )
            message = approval.get("message")
            if message:
                lines.append(f"    message: {message}")
    else:
        lines.append("approvals: none")
    for key in ("warnings", "errors"):
        values = result.get(key)
        if isinstance(values, list) and values:
            lines.append(f"{key}:")
            lines.extend(f"  - {value}" for value in values)
    return "\n".join(lines) + "\n"


def format_approval_response_text(result: Mapping[str, Any]) -> str:
    lines = [
        f"loopplane approval response: {result.get('status', 'unknown')}",
        f"workflow_id: {result.get('workflow_id') or 'unknown'}",
    ]
    response = result.get("response")
    if isinstance(response, dict):
        lines.append(f"approval_id: {response.get('approval_id')}")
        lines.append(f"decision: {response.get('decision')}")
        lines.append(f"responded_at: {response.get('responded_at')}")
    errors = result.get("errors")
    if isinstance(errors, list) and errors:
        lines.append("errors:")
        lines.extend(f"  - {error}" for error in errors)
    return "\n".join(lines) + "\n"


