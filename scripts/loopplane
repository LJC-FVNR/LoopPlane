def not_implemented(args: argparse.Namespace) -> int:
    command = " ".join(args.command_path)
    print(f"loopplane {command}: not implemented in the current standalone runtime.")
    return EXIT_GENERIC_FAILURE


def show_help(args: argparse.Namespace) -> int:
    args.help_parser.print_help()
    return 0


def workflow_missing_command(args: argparse.Namespace) -> int:
    args.help_parser.print_usage(sys.stderr)
    commands = ", ".join(WORKFLOW_HISTORY_COMMANDS)
    print(f"loopplane workflow: missing workflow command. Choose one of: {commands}.", file=sys.stderr)
    return EXIT_INVALID_CONFIG


def _nested_workspace_preflight(args: argparse.Namespace) -> dict[str, Any] | None:
    command_path = tuple(getattr(args, "command_path", ()) or ())
    if command_path not in NESTED_WORKSPACE_GUARDED_COMMANDS:
        return None
    if command_path == ("init",) and not str(getattr(args, "brief", "") or "").strip():
        return None
    project_value = _nested_guard_project_value(args, command_path)
    if project_value is None:
        return None
    try:
        result = evaluate_nested_workspace_operation(
            Path(project_value),
            command="loopplane " + " ".join(command_path),
            explicit_target=_has_explicit_project_target(args, command_path),
            workspace_namespace=getattr(args, "workspace_namespace", None),
            allow_nested_workspace=bool(getattr(args, "allow_nested_workspace", False)),
        )
    except OSError as error:
        return {
            "schema_version": "1.6",
            "ok": False,
            "status": "nested_workspace_scan_failed",
            "command": "loopplane " + " ".join(command_path),
            "project_root": str(Path(project_value).expanduser()),
            "errors": [f"Unable to scan for nested LoopPlane workspaces before running command: {error}"],
            "warnings": [],
            "recovery_actions": [
                "Check directory permissions, then rerun the command.",
                "Pass --project <target-project> or --workspace-namespace only after the target can be inspected.",
            ],
        }
    if result.get("ok") is True:
        return None
    return result


def _nested_guard_project_value(args: argparse.Namespace, command_path: tuple[str, ...]) -> str | None:
    if command_path == ("workspace", "register"):
        return str(getattr(args, "project", "") or "") or None
    if command_path == ("import",):
        return str(getattr(args, "target", "") or "") or None
    return str(getattr(args, "project", None) or ".")


def _has_explicit_project_target(args: argparse.Namespace, command_path: tuple[str, ...]) -> bool:
    if command_path == ("workspace", "register"):
        return bool(getattr(args, "project", None))
    if command_path == ("import",):
        return bool(getattr(args, "target", None))
    return getattr(args, "project", None) is not None


def _format_nested_workspace_preflight_text(result: Mapping[str, Any]) -> str:
    lines = [
        f"loopplane nested workspace guard: {result.get('status', 'unknown')}",
        f"command: {result.get('command') or 'unknown'}",
        f"project: {result.get('project_root') or 'unknown'}",
    ]
    nested = result.get("nested_workspaces")
    if isinstance(nested, Mapping):
        lines.append(f"nested_workspace_count: {nested.get('nested_workspace_count', 0)}")
        lines.append(f"parent_count: {nested.get('parent_count', 0)}")
        lines.append(f"child_count: {nested.get('child_count', 0)}")
    namespaces = result.get("valid_namespaces")
    if isinstance(namespaces, Sequence) and namespaces and not isinstance(namespaces, (str, bytes)):
        lines.append("valid_namespaces:")
        lines.extend(f"  - {namespace}" for namespace in namespaces)
    for key in ("errors", "warnings", "recovery_actions"):
        values = result.get(key)
        if isinstance(values, Sequence) and values and not isinstance(values, (str, bytes)):
            lines.append(f"{key}:")
            lines.extend(f"  - {value}" for value in values)
    return "\n".join(lines) + "\n"


COMPACT_JSON_LIST_FIELDS = frozenset(
    {
        "checks",
        "checked_files",
        "created",
        "created_directories",
        "excluded_paths",
        "files",
        "included_paths",
        "managed_files",
        "preserved",
        "protected_paths",
        "runner_results",
        "schemas_used",
        "source_files",
        "updated",
    }
)
COMPACT_JSON_SAMPLE_SIZE = 20


def _print_json_result(result: Mapping[str, Any], args: argparse.Namespace, *, compact_lists: bool = False) -> None:
    payload: Any = result
    if compact_lists and not getattr(args, "verbose_json", False):
        payload = _compact_json_lists(result)
    print(json.dumps(payload, indent=2, sort_keys=True))


def _compact_json_lists(value: Any, *, key: str | None = None) -> Any:
    if isinstance(value, Mapping):
        return {
            str(child_key): _compact_json_lists(child_value, key=str(child_key))
            for child_key, child_value in value.items()
        }
    if isinstance(value, list):
        if key in COMPACT_JSON_LIST_FIELDS:
            sample = [_compact_json_sample_item(item) for item in value[:COMPACT_JSON_SAMPLE_SIZE]]
            return {
                "count": len(value),
                "sample": sample,
                "omitted": max(0, len(value) - COMPACT_JSON_SAMPLE_SIZE),
            }
        return [_compact_json_lists(item) for item in value]
    return value


def _compact_json_sample_item(item: Any) -> Any:
    if isinstance(item, Mapping):
        for field in ("path", "checkpoint_id", "skill_root", "entrypoint", "name"):
            if field in item:
                text = str(item[field])
                if field == "path" and "reason" in item:
                    return {"path": text, "reason": str(item["reason"])}
                return text
        return {str(key): _compact_json_sample_item(value) for key, value in list(item.items())[:5]}
    return item


def _add_nested_workspace_options(parser: argparse.ArgumentParser) -> None:
    parser.add_argument(
        "--workspace-namespace",
        metavar="<workspace_id-or-project-path>",
        help=(
            "Explicitly name the targeted workspace when parent/child LoopPlane instances are nested. "
            "Accepts the target workspace_id or absolute project path."
        ),
    )
    parser.add_argument(
        "--allow-nested-workspace",
        action="store_true",
        help="Acknowledge the nested workspace boundary after manually verifying the intended target.",
    )


def run_workflow_deferred(args: argparse.Namespace) -> int:
    command_path = tuple(getattr(args, "command_path", ("workflow",)))
    command = " ".join(command_path)
    payload: dict[str, Any] = {
        "ok": False,
        "status": "deferred_implementation",
        "command": f"loopplane {command}",
        "errors": [
            (
                f"loopplane {command} is registered in the standalone CLI surface, "
                "but the workflow-history operation is not implemented yet."
            )
        ],
        "recovery_actions": [
            "Use `loopplane workspace current --project <project> --json` to inspect the current workflow pointer.",
            "Avoid editing .loopplane/workflow_registry.json or .loopplane/current_workflow.json by hand.",
            "Wait for the corresponding R11 workflow-history implementation slice before mutating workflow history.",
        ],
    }
    if getattr(args, "project", None):
        payload["project"] = str(Path(args.project).expanduser())
    if getattr(args, "workflow_id", None):
        payload["workflow_id"] = str(args.workflow_id)
    if getattr(args, "brief", None):
        payload["brief_supplied"] = True
    if getattr(args, "name", None):
        payload["name"] = str(args.name)

    if getattr(args, "json", False):
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print(f"loopplane {command}: deferred_implementation")
        for error in payload["errors"]:
            print(f"error: {error}")
        print("recovery_actions:")
        for action in payload["recovery_actions"]:
            print(f"  - {action}")
    return EXIT_GENERIC_FAILURE


def run_init(args: argparse.Namespace) -> int:
    project = Path(args.project or ".")
    warnings: list[str] = []
    existing_markers = _existing_init_markers(project)
    if existing_markers:
        resolved_project = project.expanduser().resolve()
        if args.json:
            print(
                json.dumps(
                    _init_payload(
                        resolved_project,
                        status="already_initialized",
                        ok=False,
                        errors=["Existing LoopPlane workspace detected; refusing to reinitialize."],
                        warnings=[],
                        existing_markers=existing_markers,
                    ),
                    indent=2,
                    sort_keys=True,
                )
            )
            return EXIT_INVALID_CONFIG
        print("loopplane init: existing LoopPlane workspace detected; refusing to reinitialize.")
        print(f"project: {resolved_project}")
        print("existing markers:")
        for marker in existing_markers:
            print(f"  - {marker}")
        print("No workspace files were changed.")
        print(f"Use `loopplane status --project {resolved_project}` to inspect the current workflow.")
        print(f"Use `loopplane attach --project {resolved_project}` or `loopplane resume --project {resolved_project}` for an existing workflow.")
        print("Create a new same-workspace workflow only through an explicit workflow-history command.")
        return EXIT_INVALID_CONFIG

    if not args.brief or not args.brief.strip():
        if args.json:
            print(
                json.dumps(
                    _init_payload(
                        project.expanduser().resolve(),
                        status="missing_brief",
                        ok=False,
                        errors=["--brief is required."],
                        warnings=[],
                    ),
                    indent=2,
                    sort_keys=True,
                )
            )
            return EXIT_INVALID_CONFIG
        print("loopplane init: --brief is required.")
        return EXIT_INVALID_CONFIG

    nesting = _detect_init_nesting(project)
    if int(nesting.get("nested_workspace_count") or 0) > 0:
        warnings.extend(str(warning) for warning in nesting.get("warnings", []))
        if not args.json:
            print("warning: nested LoopPlane workspace context detected.")
            for warning in nesting.get("warnings", []):
                print(f"  - {warning}")
            print("Nested workspace operations require an explicit namespace or approval before crossing boundaries.")

    try:
        result = init_project(project, args.brief, layout=LAYOUT_CANONICAL_V16)
    except InitConflictError as error:
        if args.json:
            print(
                json.dumps(
                    _init_payload(
                        project.expanduser().resolve(),
                        status="conflict",
                        ok=False,
                        errors=list(error.conflicts),
                        warnings=warnings,
                    ),
                    indent=2,
                    sort_keys=True,
                )
            )
            return EXIT_INVALID_CONFIG
        print("loopplane init: refusing to overwrite existing files.")
        for conflict in error.conflicts:
            print(f"  - {conflict}")
        print("Use an explicit migration or approval path before changing these files.")
        return EXIT_INVALID_CONFIG
    except WorkflowPathError as error:
        if args.json:
            print(
                json.dumps(
                    _init_payload(
                        project.expanduser().resolve(),
                        status="invalid_workflow_path",
                        ok=False,
                        errors=[str(error)],
                        warnings=warnings,
                    ),
                    indent=2,
                    sort_keys=True,
                )
            )
            return EXIT_INVALID_CONFIG
        print(f"loopplane init: invalid workflow path configuration: {error}")
        return EXIT_INVALID_CONFIG

    schema_validation = validate_project_schemas(result.project)
    if not schema_validation.get("ok"):
        if args.json:
            payload = _init_payload(
                result.project,
                status="schema_validation_failed",
                ok=False,
                errors=[str(error) for error in schema_validation.get("errors", [])],
                warnings=[*warnings, *[str(warning) for warning in schema_validation.get("warnings", [])]],
                result=result,
            )
            payload["schema_validation"] = schema_validation
            print(json.dumps(payload, indent=2, sort_keys=True))
            return schema_validation_exit_code(schema_validation)
        print(format_schema_validation_text(schema_validation), end="")
        return schema_validation_exit_code(schema_validation)

    if args.json:
        ok = result.version_control_status != "waiting_config"
        payload = _init_payload(
            result.project,
            status="initialized" if ok else "waiting_config",
            ok=ok,
            errors=[] if ok else [result.version_control_problem or "version_control_unavailable"],
            warnings=warnings,
            result=result,
        )
        print(json.dumps(payload, indent=2, sort_keys=True))
        return 0 if ok else EXIT_INVALID_CONFIG

    print(f"Initialized LoopPlane workflow {result.workflow_id} at {result.project}")
    if result.created:
        print(f"Created {len(result.created)} files.")
    if result.preserved:
        print(f"Preserved {len(result.preserved)} existing files.")
    print(
        "Next step: configure a usable worker runner, for example "
        "`loopplane configure-agent --project <project> --runner worker --role worker --adapter codex_cli --command codex` "
        "or a shell runner with `--arg` and `--prompt-delivery-mode stdin`."
    )
    if result.version_control_status == "waiting_config":
        print("Version control status: waiting_config")
        if result.version_control_problem:
            print(f"Configuration problem: {result.version_control_problem}")
        return EXIT_INVALID_CONFIG
    return 0


def _init_payload(
    project: Path,
    *,
    status: str,
    ok: bool,
    errors: Sequence[str],
    warnings: Sequence[str],
    result: Any | None = None,
    existing_markers: Sequence[str] = (),
) -> dict[str, Any]:
    payload: dict[str, Any] = {
        "schema_version": "1.5",
        "ok": ok,
        "status": status,
        "project_root": project.as_posix(),
        "workflow_id": None,
        "workspace_id": None,
        "created": [],
        "preserved": [],
        "version_control_status": None,
        "version_control_problem": None,
        "errors": list(errors),
        "warnings": list(warnings),
    }
    if existing_markers:
        payload["existing_markers"] = list(existing_markers)
    if result is not None:
        payload.update(
            {
                "project_root": result.project.as_posix(),
                "workflow_id": result.workflow_id,
                "workspace_id": result.workspace_id,
                "created": list(result.created),
                "preserved": list(result.preserved),
                "version_control_status": result.version_control_status,
                "version_control_problem": result.version_control_problem,
            }
        )
    return payload


def _detect_init_nesting(project: Path) -> dict[str, Any]:
    try:
        return detect_nested_loopplane_instances(project)
    except OSError as error:
        return {
            "nested_workspace_count": 0,
            "warnings": [f"Unable to scan for nested LoopPlane workspaces before init: {error}"],
        }


def _existing_init_markers(project: Path) -> list[str]:
    root = project.expanduser()
    markers = (
        ".loopplane/workspace.json",
        ".loopplane/config/instance.json",
        ".loopplane/config/workflow.json",
    )
    return [marker for marker in markers if (root / marker).exists()]


