def add_stub(
    subparsers: argparse._SubParsersAction[argparse.ArgumentParser],
    name: str,
    help_text: str,
    *,
    command_path: Sequence[str] | None = None,
    description: str | None = None,
) -> argparse.ArgumentParser:
    parser = subparsers.add_parser(
        name,
        help=help_text,
        description=description or help_text,
    )
    parser.set_defaults(
        handler=not_implemented,
        command_path=list(command_path or (name,)),
    )
    return parser


def add_skill_commands(subparsers: argparse._SubParsersAction[argparse.ArgumentParser]) -> None:
    parser = subparsers.add_parser(
        "skill",
        help="Skill package doctor, install, update, and pack commands.",
        description="Skill package commands.",
    )
    parser.set_defaults(handler=show_help, help_parser=parser)
    skill_subparsers = parser.add_subparsers(
        dest="skill_command",
        metavar="<skill-command>",
        title="skill commands",
    )

    doctor = skill_subparsers.add_parser(
        "doctor",
        help="Check the installed LoopPlane skill package.",
        description="Check required LoopPlane portable package files, directories, scripts, and metadata.",
    )
    doctor.add_argument(
        "--package-root",
        metavar="<path>",
        help="Package root to inspect. Defaults to the current LoopPlane package.",
    )
    doctor.add_argument("--json", action="store_true", help="Emit a machine-readable doctor report.")
    doctor.add_argument("--verbose-json", action="store_true", help="With --json, include full diagnostic lists instead of compact count/sample summaries.")
    doctor.set_defaults(handler=run_skill_doctor, command_path=("skill", "doctor"))

    install = skill_subparsers.add_parser(
        "install",
        help="Install LoopPlane into a target project.",
        description="Materialize a project-local LoopPlane workflow instance without overwriting existing files.",
    )
    install.add_argument("--target", metavar="<project>", help="Project path to install into.")
    install.add_argument(
        "--agent-style",
        choices=("codex", "claude", "claude_code"),
        action="append",
        help="Install only the selected project-local agent skill projection. May be repeated.",
    )
    install.add_argument(
        "--all-agent-skills",
        action="store_true",
        help="Install all supported project-local agent skill projections. This is the default.",
    )
    install.add_argument(
        "--no-agent-skill-projection",
        action="store_true",
        help="Skip project-local .codex/.claude skill projections during install.",
    )
    install.add_argument("--json", action="store_true", help="Emit a machine-readable install report.")
    install.add_argument("--verbose-json", action="store_true", help="With --json, include full file lists instead of compact count/sample summaries.")
    install.set_defaults(handler=run_skill_install, command_path=("skill", "install"))
    update = skill_subparsers.add_parser(
        "update",
        help="Update LoopPlane-managed metadata in a target project.",
        description=(
            "Refresh project-local LoopPlane package metadata and missing v1.6 flat-layout "
            "metadata without overwriting workflow state or project artifacts."
        ),
    )
    update.add_argument("--target", metavar="<project>", help="Project path to update.")
    update.add_argument("--json", action="store_true", help="Emit a machine-readable update report.")
    update.set_defaults(handler=run_skill_update, command_path=("skill", "update"))
    pack = skill_subparsers.add_parser(
        "pack",
        help="Package the LoopPlane skill bundle.",
        description="Validate the portable package and create a deterministic ZIP bundle.",
    )
    pack.add_argument(
        "--package-root",
        metavar="<path>",
        help="Package root to bundle. Defaults to the current LoopPlane package.",
    )
    pack.add_argument(
        "--output",
        metavar="<path>",
        help="Artifact path or existing output directory. Defaults to dist/<package>-<version>.zip.",
    )
    pack.add_argument("--json", action="store_true", help="Emit a machine-readable pack report.")
    pack.set_defaults(handler=run_skill_pack, command_path=("skill", "pack"))


def add_agent_runner_commands(subparsers: argparse._SubParsersAction[argparse.ArgumentParser]) -> None:
    configure = subparsers.add_parser(
        "configure-agent",
        help="Configure or inspect agent runners.",
        description="Configure or inspect project-local agent runner configuration.",
    )
    configure.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    configure.add_argument("--runner", help="Specific runner id to inspect or configure.")
    configure.add_argument("--role", help="Runner role, such as planner, auditor, worker, validator, summary, or inspector.")
    configure.add_argument("--adapter", help="Adapter identifier, such as shell, codex_cli, or claude_code_cli.")
    configure.add_argument("--command", help="Underlying executable command for the runner.")
    configure.add_argument("--arg", dest="runner_arg", action="append", help="Append one runner argument. May be repeated.")
    configure.add_argument("--cwd", help="Runner working directory. Supports {{project_root}}.")
    configure.add_argument("--prompt-delivery-mode", help="Prompt delivery mode, such as stdin, file_argument, or stdin_or_prompt_flag.")
    configure.add_argument("--prompt-argument-template", help="Argument template for file_argument prompt delivery.")
    configure.add_argument("--prompt-flag", help="Prompt flag for stdin_or_prompt_flag delivery.")
    configure.add_argument("--prompt-file", help="Prompt file template for prompt delivery modes that need one.")
    configure.add_argument("--timeout-seconds", type=int, help="Runner timeout in seconds.")
    configure.add_argument("--env", action="append", help="Set one runner environment variable using KEY=VALUE. May be repeated.")
    configure.add_argument("--model", help="Model name to pass to compatible agent CLI adapters.")
    configure.add_argument(
        "--reasoning-effort",
        choices=("low", "medium", "high", "xhigh"),
        help="Reasoning/effort level to pass to compatible agent CLI adapters.",
    )
    configure.add_argument(
        "--codex-sandbox",
        choices=("read-only", "workspace-write", "danger-full-access"),
        help="Override the default Codex CLI sandbox for a codex_cli runner.",
    )
    configure.add_argument(
        "--doctor-check-command",
        help="Explicit command used by doctor-agent for runner readiness; mutually exclusive with --no-version-check.",
    )
    configure.add_argument(
        "--no-version-check",
        action="store_true",
        help="Do not configure a runner version command; mutually exclusive with --doctor-check-command.",
    )
    configure.add_argument("--prune", action="store_true", help="Remove stale LOOPPLANE_HOME runner overrides for deleted projects.")
    _add_nested_workspace_options(configure)
    configure.add_argument("--json", action="store_true", help="Emit a machine-readable configuration report.")
    configure.set_defaults(handler=run_configure_agent, command_path=("configure-agent",))

    doctor = subparsers.add_parser(
        "doctor-agent",
        help="Inspect agent runner availability.",
        description="Inspect one or more configured agent runners.",
    )
    doctor.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    doctor_selection = doctor.add_mutually_exclusive_group()
    doctor_selection.add_argument("--runner", help="Specific runner id to inspect.")
    doctor_selection.add_argument("--all", action="store_true", help="Inspect all configured runners.")
    doctor_selection.add_argument("--required", action="store_true", help="Inspect enabled runners required for normal workflow execution.")
    _add_nested_workspace_options(doctor)
    doctor.add_argument("--json", action="store_true", help="Emit a machine-readable doctor report.")
    doctor.set_defaults(handler=run_doctor_agent, command_path=("doctor-agent",))


def add_planning_commands(subparsers: argparse._SubParsersAction[argparse.ArgumentParser]) -> None:
    init = add_stub(subparsers, "init", "Create a project-local LoopPlane workflow instance.")
    init.add_argument("--project", metavar="<path>", help="Project path to initialize.")
    init.add_argument("--brief", metavar="<text>", help="Initial project brief text.")
    _add_nested_workspace_options(init)
    init.add_argument("--json", action="store_true", help="Emit a machine-readable init report.")
    init.set_defaults(handler=run_init, command_path=("init",))

    write_brief = subparsers.add_parser(
        "write-brief",
        help="Create or update the project brief.",
        description=(
            "Create or update the configured PROJECT_BRIEF.md. Existing different "
            "content is refused unless --force is supplied."
        ),
    )
    write_brief.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    write_brief.add_argument("--text", metavar="<text>", help="Brief text to write.")
    write_brief.add_argument("--file", metavar="<path>", help="Read brief content from a UTF-8 text file.")
    write_brief.add_argument("--brief-file", dest="brief_file", metavar="<path>", help="Alias for --file.")
    write_brief.add_argument("--stdin", action="store_true", help="Read brief content from standard input.")
    write_brief.add_argument("--force", action="store_true", help="Replace an existing different brief file.")
    _add_nested_workspace_options(write_brief)
    write_brief.add_argument("--json", action="store_true", help="Emit a machine-readable write report.")
    write_brief.add_argument("--verbose-json", action="store_true", help="With --json, include full checkpoint file lists instead of compact count/sample summaries.")
    write_brief.set_defaults(handler=run_write_brief, command_path=("write-brief",))
    plan = subparsers.add_parser(
        "plan",
        help="Run planner workflow and produce a plan draft.",
        description="Run the configured planner agent and produce PLAN_DRAFT.md.",
    )
    plan.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    plan.add_argument("--runner", help="Planner runner id override.")
    plan.add_argument(
        "--progress-interval",
        type=float,
        default=30.0,
        metavar="<seconds>",
        help="Emit planner heartbeat summaries to stderr while waiting. Use 0 to disable.",
    )
    _add_nested_workspace_options(plan)
    plan.add_argument("--json", action="store_true", help="Emit a machine-readable planner result.")
    plan.set_defaults(handler=run_plan, command_path=("plan",))
    audit = subparsers.add_parser(
        "audit-plan",
        help="Run optional plan audit workflow.",
        description="Run the configured auditor agent over PLAN_DRAFT.md.",
    )
    audit.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    audit.add_argument("--runner", help="Auditor runner id override.")
    audit.add_argument(
        "--progress-interval",
        type=float,
        default=30.0,
        metavar="<seconds>",
        help="Emit auditor heartbeat summaries to stderr while waiting. Use 0 to disable.",
    )
    _add_nested_workspace_options(audit)
    audit.add_argument("--json", action="store_true", help="Emit a machine-readable auditor result.")
    audit.set_defaults(handler=run_audit_plan, command_path=("audit-plan",))
    revise = subparsers.add_parser(
        "revise-plan",
        help="Run bounded plan revision until readiness and required audit pass.",
        description="Run the planner/auditor plan revision loop with persisted planning state.",
    )
    revise.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    revise.add_argument("--planner-runner", help="Planner runner id override.")
    revise.add_argument("--auditor-runner", help="Auditor runner id override.")
    revise.add_argument("--max-iterations", type=int, help="Override planning.max_planner_iterations for this run.")
    revise.add_argument(
        "--progress-interval",
        type=float,
        default=30.0,
        metavar="<seconds>",
        help="Emit planner/auditor heartbeat summaries to stderr while waiting. Use 0 to disable.",
    )
    _add_nested_workspace_options(revise)
    revise.add_argument("--json", action="store_true", help="Emit a machine-readable revision loop result.")
    revise.set_defaults(handler=run_revise_plan, command_path=("revise-plan",))

    acknowledge = subparsers.add_parser(
        "acknowledge-plan",
        help="Acknowledge an intentional active PLAN.md edit.",
        description=(
            "Re-parse active PLAN.md, refresh its accepted hash, clear manual-plan-change blocking state, "
            "and synchronize active workflow projections after an intentional plan edit."
        ),
    )
    acknowledge.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    _add_nested_workspace_options(acknowledge)
    acknowledge.add_argument("--json", action="store_true", help="Emit a machine-readable acknowledgement report.")
    acknowledge.set_defaults(handler=run_acknowledge_plan, command_path=("acknowledge-plan",))

    activate = subparsers.add_parser(
        "activate-plan",
        help="Activate a readiness-checked plan draft.",
        description="Promote PLAN_DRAFT.md to active PLAN.md after readiness and required audit checks pass.",
    )
    activate.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    _add_nested_workspace_options(activate)
    activate.add_argument("--json", action="store_true", help="Emit a machine-readable activation result.")
    activate.add_argument("--verbose-json", action="store_true", help="With --json, include full checkpoint file lists instead of compact count/sample summaries.")
    activate.add_argument("--file", metavar="<path>", help="Import this plan file as PLAN_DRAFT.md before activation checks.")
    activate.set_defaults(handler=run_activate_plan, command_path=("activate-plan",))


def add_execution_commands(subparsers: argparse._SubParsersAction[argparse.ArgumentParser]) -> None:
    start = subparsers.add_parser(
        "start",
        help="Request workflow execution start.",
        description="Append a durable start control request for the scheduler to apply.",
    )
    start.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    start.add_argument("--detach", action="store_true", help="Run the scheduler in the background.")
    _add_nested_workspace_options(start)
    start.add_argument("--json", action="store_true", help="Emit a machine-readable control request report.")
    start.set_defaults(handler=run_start, command_path=("start",), control_type="start")

    run = subparsers.add_parser(
        "run",
        help="Run the scheduler loop.",
        description="Run the durable scheduler loop for the project.",
    )
    run.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    run.add_argument("--dry-run", action="store_true", help="Preview work without executing agents.")
    run.add_argument("--max-ticks", type=int, default=1, help="Maximum scheduler ticks for this invocation.")
    run.add_argument(
        "--until-complete",
        action="store_true",
        help="Keep ticking until the workflow completes, waits, fails, or reaches a large safety cap.",
    )
    run.add_argument(
        "--progress-interval",
        type=float,
        default=30.0,
        metavar="<seconds>",
        help="Emit active-run heartbeat summaries to stderr while waiting. Use 0 to disable.",
    )
    run.add_argument(
        "--summary",
        action="store_true",
        help="Emit a compact scheduler summary instead of the default detailed text; with --json, emit compact JSON.",
    )
    _add_nested_workspace_options(run)
    run.add_argument("--json", action="store_true", help="Emit a machine-readable scheduler result.")
    run.set_defaults(handler=run_scheduler_command, command_path=("run",))

    preview = subparsers.add_parser(
        "preview",
        help="Preview scheduler decisions.",
        description="Preview the next scheduler action without mutating authoritative workflow state.",
    )
    preview.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    _add_nested_workspace_options(preview)
    preview.add_argument("--json", action="store_true", help="Emit machine-readable preview output.")
    preview.add_argument(
        "--write",
        action="store_true",
        help="Write non-authoritative preview_result.json under the resolved runtime directory.",
    )
    preview.set_defaults(handler=run_preview, command_path=("preview",))

    tick = subparsers.add_parser(
        "tick",
        help="Run a single scheduler tick.",
        description="Run exactly one durable scheduler tick.",
    )
    tick.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    _add_nested_workspace_options(tick)
    tick.add_argument(
        "--progress-interval",
        type=float,
        default=30.0,
        metavar="<seconds>",
        help="Emit active-run heartbeat summaries to stderr while waiting. Use 0 to disable.",
    )
    tick.add_argument(
        "--summary",
        action="store_true",
        help="Emit a compact scheduler summary instead of the default detailed text; with --json, emit compact JSON.",
    )
    tick.add_argument("--json", action="store_true", help="Emit a machine-readable scheduler result.")
    tick.set_defaults(handler=run_scheduler_command, command_path=("tick",), dry_run=False, max_ticks=1)
    pause = subparsers.add_parser(
        "pause",
        help="Request workflow execution pause.",
        description="Append a durable pause control request for the scheduler to apply at a safe point.",
    )
    pause.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    _add_nested_workspace_options(pause)
    pause.add_argument("--json", action="store_true", help="Emit a machine-readable control request report.")
    pause.set_defaults(handler=run_control_request, command_path=("pause",), control_type="pause")

    resume = subparsers.add_parser(
        "resume",
        help="Request workflow execution resume.",
        description="Append a durable resume control request for the scheduler to apply.",
    )
    resume.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    resume.add_argument(
        "--foreground-owner",
        action="store_true",
        help="Record resume without launching a detached supervisor; the caller must immediately run the supervisor.",
    )
    resume.add_argument(
        "--clear-runner-availability-holds",
        action="store_true",
        help=(
            "Explicitly clear automatic runner cooldown holds after independently verifying live runner "
            "availability; the action is recorded against this resume request."
        ),
    )
    _add_nested_workspace_options(resume)
    resume.add_argument("--json", action="store_true", help="Emit a machine-readable control request report.")
    resume.set_defaults(handler=run_resume, command_path=("resume",), control_type="resume")

    stop = subparsers.add_parser(
        "stop",
        help="Request workflow execution stop.",
        description="Append a durable stop control request for the scheduler to apply at a safe point.",
    )
    stop.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    _add_nested_workspace_options(stop)
    stop.add_argument("--json", action="store_true", help="Emit a machine-readable control request report.")
    stop.set_defaults(handler=run_control_request, command_path=("stop",), control_type="stop")

    attach = subparsers.add_parser(
        "attach",
        help="Attach to a detached runtime.",
        description="Show a bounded tail of the active detached scheduler runtime when a supervisor is running.",
    )
    attach.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    attach.add_argument("--lines", type=int, default=50, help="Maximum recent records/log lines to show. Defaults to 50.")
    attach.add_argument("--follow", action="store_true", help="Poll briefly before returning instead of taking one snapshot.")
    attach.add_argument(
        "--timeout",
        type=float,
        default=0.0,
        help="Maximum seconds to poll with --follow. Defaults to 0.",
    )
    attach.add_argument(
        "--poll-interval",
        type=float,
        default=0.2,
        help="Polling interval in seconds for --follow. Defaults to 0.2.",
    )
    attach.add_argument(
        "--request",
        action="store_true",
        help="Append a durable attach control request instead of attaching to the current supervisor.",
    )
    _add_nested_workspace_options(attach)
    attach.add_argument("--json", action="store_true", help="Emit a machine-readable attach report.")
    attach.set_defaults(handler=run_attach, command_path=("attach",), control_type="attach")

    status = subparsers.add_parser(
        "status",
        help="Show workflow status.",
        description="Show runtime state, scheduler control state, and durable control request status.",
    )
    status.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    _add_nested_workspace_options(status)
    status.add_argument("--json", action="store_true", help="Emit machine-readable workflow status.")
    status.set_defaults(handler=run_status, command_path=("status",))

    health = subparsers.add_parser(
        "health",
        help="Run runtime health checks.",
        description="Inspect authoritative runtime files and report LoopPlane runtime health.",
    )
    health.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    _add_nested_workspace_options(health)
    health.add_argument("--json", action="store_true", help="Emit machine-readable health output.")
    health.add_argument("--workflow", metavar="<workflow_id>", help="Check a registered workflow without changing current_workflow.json.")
    health.add_argument("--all", action="store_true", help="Check every workflow in the current workspace.")
    health.add_argument("--strict", action="store_true", help="Return non-zero for advisory health warnings.")
    health.add_argument("--write", action="store_true", help="Write health_report.json under the resolved runtime directory.")
    health.set_defaults(handler=run_health, command_path=("health",))

    validate = subparsers.add_parser(
        "validate",
        help="Run authoritative validation for a worker evidence run.",
        description="Run the deterministic validator and write authoritative validation.json.",
    )
    validate.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    validate.add_argument("--task", required=True, help="Primary task id to validate.")
    validate.add_argument("--run-dir", required=True, metavar="<path>", help="Worker evidence run directory.")
    validate.add_argument("--json", action="store_true", help="Emit machine-readable validation output.")
    validate.add_argument("--no-write", action="store_true", help="Do not write validation.json or validator.log.")
    _add_nested_workspace_options(validate)
    validate.set_defaults(handler=run_validate, command_path=("validate",))

    reconcile = subparsers.add_parser(
        "reconcile",
        help="Apply authoritative validation to plan and runtime state.",
        description="Run the reconciler over an authoritative validation.json and update plan, latest pointers, failures, approvals, events, and read-model rebuild triggers.",
    )
    reconcile.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    reconcile.add_argument("--task", help="Primary task id expected in validation.json.")
    reconcile.add_argument("--run-dir", metavar="<path>", help="Worker evidence run directory containing validation.json.")
    reconcile.add_argument("--validation", metavar="<path>", help="Explicit validation.json path.")
    reconcile.add_argument("--json", action="store_true", help="Emit machine-readable reconciliation output.")
    reconcile.add_argument("--no-write", action="store_true", help="Validate reconciliation inputs without mutating authoritative files.")
    _add_nested_workspace_options(reconcile)
    reconcile.set_defaults(handler=run_reconcile, command_path=("reconcile",))

    summarize = subparsers.add_parser(
        "summarize",
        help="Generate human-readable task and phase summaries.",
        description=(
            "Generate concise human-readable task summaries for terminal tasks and phase summaries "
            "for phases whose tasks are all terminal. Reconciliation runs this automatically after "
            "accepted validations; this command backfills or refreshes summary artifacts."
        ),
    )
    summarize.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    summarize.add_argument(
        "--task",
        action="append",
        metavar="<task-id>",
        help="Task id to summarize. Repeat to summarize multiple tasks. Defaults to all terminal tasks.",
    )
    summarize.add_argument("--force", action="store_true", help="Regenerate summaries even when source hashes are current.")
    summarize.add_argument("--no-write", action="store_true", help="Preview summary generation without writing artifacts.")
    summarize.add_argument("--json", action="store_true", help="Emit machine-readable summary generation output.")
    _add_nested_workspace_options(summarize)
    summarize.set_defaults(handler=run_summarize, command_path=("summarize",))

    logs = subparsers.add_parser(
        "logs",
        help="Show workflow logs.",
        description="Show recent runtime events and control request/response records.",
    )
    logs.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    logs.add_argument("--lines", type=int, default=50, help="Maximum recent records to show. Defaults to 50.")
    _add_nested_workspace_options(logs)
    logs.add_argument("--json", action="store_true", help="Emit machine-readable logs.")
    logs.set_defaults(handler=run_logs, command_path=("logs",))

    rebuild = subparsers.add_parser(
        "rebuild-read-models",
        help="Rebuild derived runtime read models.",
        description="Rebuild dashboard read models from PLAN.md, latest pointers, validations, event snapshots, event logs, and sanitized version-control status.",
    )
    rebuild.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    _add_nested_workspace_options(rebuild)
    rebuild.add_argument("--workflow", metavar="<workflow_id>", help="Rebuild read models for a registered workflow without changing current_workflow.json.")
    rebuild.add_argument(
        "--max-dashboard-events",
        type=int,
        metavar="<count>",
        help="Maximum recent events included in dashboard graph/feed read models. Defaults to dashboard config or 200.",
    )
    rebuild.add_argument("--json", action="store_true", help="Emit a machine-readable rebuild report.")
    rebuild.add_argument("--no-write", action="store_true", help="Validate generated read models without writing them.")
    rebuild.add_argument(
        "--strict-diagnostics",
        action="store_true",
        help="Run explicit read-only diagnostics with full event-log hashes and payload sidecar verification.",
    )
    rebuild.add_argument(
        "--compare-rebuild",
        action="store_true",
        help="With --strict-diagnostics, also run a no-write rebuild and compare generated read models with files on disk.",
    )
    rebuild.set_defaults(handler=run_rebuild_read_models, command_path=("rebuild-read-models",))

    final_verify = subparsers.add_parser(
        "final-verify",
        help="Run deterministic final verification.",
        description="Run deterministic global completion checks and write the final report plus completion marker only on pass.",
    )
    final_verify.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    _add_nested_workspace_options(final_verify)
    final_verify.add_argument("--json", action="store_true", help="Emit a machine-readable final verification report.")
    final_verify.add_argument("--no-write", action="store_true", help="Run checks without writing report, marker, events, or checkpoints.")
    final_verify.add_argument("--force", action="store_true", help="Write a new final verification report, marker, and checkpoints even when the existing completion marker is fresh.")
    final_verify.set_defaults(handler=run_final_verify, command_path=("final-verify",))

    verify_objectives = subparsers.add_parser(
        "verify-objectives",
        help="Run agentic objective verification.",
        description="Run the objective verifier for a pending phase or workflow objective gate.",
    )
    verify_objectives.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    _add_nested_workspace_options(verify_objectives)
    verify_objectives.add_argument("--scope", choices=("auto", "phase", "workflow"), default="auto", help="Objective gate scope to verify.")
    verify_objectives.add_argument("--phase-id", metavar="<phase-id>", help="Specific phase objective id, for example P0.")
    verify_objectives.add_argument("--force", action="store_true", help="Run even if the selected objective gate is already closed or waiting for expansion.")
    verify_objectives.add_argument("--json", action="store_true", help="Emit a machine-readable objective verification result.")
    verify_objectives.set_defaults(handler=run_verify_objectives, command_path=("verify-objectives",))

    migrate = subparsers.add_parser(
        "migrate",
        help="Run explicit schema migrations.",
        description="Run explicit project-local schema migrations and derived-runtime repair operations.",
    )
    migrate.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    migrate.add_argument("--workflow", metavar="<workflow_id>", help="Target a registered workflow without changing current_workflow.json.")
    migrate.add_argument("--dry-run", action="store_true", help="Report the planned migration without modifying files.")
    migrate.add_argument(
        "--repair-event-manifest",
        action="store_true",
        help="Rebuild runtime/events/manifest.json from existing event JSONL segments without modifying event records.",
    )
    migrate.add_argument(
        "--compact-event-payloads",
        action="store_true",
        help="Move large historical event payloads after the latest snapshot into sidecars and rewrite the affected event chain.",
    )
    migrate.add_argument(
        "--compact-all-events",
        action="store_true",
        help="With --compact-event-payloads, allow rewriting events before the latest snapshot as well.",
    )
    migrate.add_argument(
        "--payload-threshold-bytes",
        type=int,
        metavar="<bytes>",
        help="Payload size threshold for --compact-event-payloads. Defaults to the scheduler sidecar threshold.",
    )
    migrate.add_argument(
        "--split-run-summaries",
        action="store_true",
        help=(
            "Split legacy read_models/run_summaries.jsonl into run_index.jsonl and per-run "
            "run_details without deleting the legacy file."
        ),
    )
    _add_nested_workspace_options(migrate)
    migrate.add_argument("--json", action="store_true", help="Emit a machine-readable migration report.")
    migrate.set_defaults(handler=run_migrate, command_path=("migrate",))


def add_background_commands(subparsers: argparse._SubParsersAction[argparse.ArgumentParser]) -> None:
    background = subparsers.add_parser(
        "background",
        help="Start and inspect LoopPlane-managed background jobs.",
        description=(
            "Run long-lived commands under LoopPlane supervision. Background jobs are recorded in "
            "the workflow runtime registry so the scheduler can wait instead of advancing unsafely."
        ),
    )
    background.set_defaults(handler=show_help, help_parser=background, command_path=("background",))
    background_subparsers = background.add_subparsers(
        dest="background_command",
        metavar="<background-command>",
        title="background commands",
    )

    start = background_subparsers.add_parser(
        "start",
        help="Start a command under LoopPlane background supervision.",
        description=(
            "Start a long-running command with a LoopPlane supervisor process. Use '--' before "
            "the command. The JSON result includes an agent_status_fragment for workers that "
            "need to report running_background."
        ),
    )
    start.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    start.add_argument("--workflow", metavar="<workflow_id>", help="Target a registered workflow without changing current_workflow.json.")
    start.add_argument("--job-id", metavar="<job_id>", help="Explicit background job id. Defaults to a generated id.")
    start.add_argument("--label", help="Short human label for the background job.")
    start.add_argument("--task", help="Task id that owns this background job. Defaults to LOOPPLANE_TASK_ID when present.")
    start.add_argument("--run", help="Run id that owns this background job. Defaults to LOOPPLANE_RUN_ID when present.")
    start.add_argument("--cwd", metavar="<path>", help="Working directory for the command. Defaults to the project root.")
    start.add_argument("--env", action="append", help="Set one command environment variable using KEY=VALUE. May be repeated.")
    start.add_argument("--timeout-seconds", type=int, help="Mark the job timed_out if it runs longer than this many seconds.")
    start.add_argument(
        "--watchdog-interval-seconds",
        type=int,
        help="Periodically run an inspector agent while the job is active. Disabled unless set.",
    )
    start.add_argument("--watchdog-runner", help="Inspector runner id for background watchdog checks. Defaults to inspector when watchdog is enabled.")
    start.add_argument(
        "--watchdog-question",
        help="Optional custom question/invariant for each background watchdog inspection.",
    )
    start.add_argument(
        "--wake-next-agent-when",
        help="Human-readable wake condition recorded for scheduler/dashboard inspection.",
    )
    start.add_argument("--shell", action="store_true", help="Run the command through the platform shell.")
    _add_nested_workspace_options(start)
    start.add_argument("--json", action="store_true", help="Emit a machine-readable start result.")
    start.add_argument("command", nargs=argparse.REMAINDER, help="Command to run after '--'.")
    start.set_defaults(handler=run_background_start, command_path=("background", "start"))

    status = background_subparsers.add_parser(
        "status",
        help="List LoopPlane-managed background jobs.",
        description="Inspect background_jobs.json and refresh simple process/exit-code derived statuses.",
    )
    status.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    status.add_argument("--workflow", metavar="<workflow_id>", help="Target a registered workflow without changing current_workflow.json.")
    status.add_argument("--job", metavar="<job_id>", help="Show only one background job.")
    status.add_argument("--no-refresh", action="store_true", help="Read the registry without deriving fresh status fields.")
    _add_nested_workspace_options(status)
    status.add_argument("--json", action="store_true", help="Emit a machine-readable status result.")
    status.set_defaults(handler=run_background_status, command_path=("background", "status"))

    complete = background_subparsers.add_parser(
        "complete",
        help="Manually resolve a background job.",
        description="Mark a background job completed or in another terminal/recovery status.",
    )
    complete.add_argument("job_id", metavar="<job_id>", help="Background job id to update.")
    complete.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    complete.add_argument("--workflow", metavar="<workflow_id>", help="Target a registered workflow without changing current_workflow.json.")
    complete.add_argument(
        "--status",
        choices=("completed", "failed", "timed_out", "cancelled", "needs_recovery"),
        default="completed",
        help="Status to record. Defaults to completed.",
    )
    complete.add_argument("--reason", help="Optional manual resolution reason.")
    _add_nested_workspace_options(complete)
    complete.add_argument("--json", action="store_true", help="Emit a machine-readable completion result.")
    complete.set_defaults(handler=run_background_complete, command_path=("background", "complete"))

    cancel = background_subparsers.add_parser(
        "cancel",
        help="Cancel a LoopPlane-managed background job.",
        description="Terminate the recorded process group when possible and mark the job cancelled.",
    )
    cancel.add_argument("job_id", metavar="<job_id>", help="Background job id to cancel.")
    cancel.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    cancel.add_argument("--workflow", metavar="<workflow_id>", help="Target a registered workflow without changing current_workflow.json.")
    cancel.add_argument("--reason", help="Optional cancellation reason.")
    _add_nested_workspace_options(cancel)
    cancel.add_argument("--json", action="store_true", help="Emit a machine-readable cancellation result.")
    cancel.set_defaults(handler=run_background_cancel, command_path=("background", "cancel"))


def add_migration_commands(subparsers: argparse._SubParsersAction[argparse.ArgumentParser]) -> None:
    export = subparsers.add_parser(
        "export",
        help="Export a LoopPlane project through a migration profile.",
        description=(
            "Create a migration archive from project-local files inside the workspace boundary. "
            "The source profile preserves portable source/evidence metadata; the stateful and "
            "archive profiles also preserve workflow events, snapshots, failure registry, "
            "historical results, and final reports. Archive exports declare read-only viewing "
            "intent for later imports. Export excludes stale process state, dashboard tokens, locks, "
            "leases, machine-local runner overrides, derived read models, and sibling workspaces."
        ),
    )
    export.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    export.add_argument(
        "--profile",
        required=True,
        choices=("source", "stateful", "archive"),
        help="Migration profile to export.",
    )
    export.add_argument("--output", required=True, metavar="<archive>", help="Archive path to create.")
    _add_nested_workspace_options(export)
    export.add_argument("--json", action="store_true", help="Emit a machine-readable export report.")
    export.add_argument("--verbose-json", action="store_true", help="With --json, include full manifest file lists instead of compact count/sample summaries.")
    export.set_defaults(handler=run_export, command_path=("export",))

    import_cmd = subparsers.add_parser(
        "import",
        help="Import a LoopPlane migration archive into a new target project.",
        description=(
            "Restore project-local workflow truth and evidence from a stateful migration archive, or import an "
            "archive-profile migration with --read-only for dashboard-only viewing. The target project must be "
            "absent or empty. Import validates the archive manifest, member hashes, path boundaries, and schemas "
            "before installing files. It refuses stale process state, machine-local overrides, derived read models, "
            "unsafe members, and archive-profile imports that omit --read-only."
        ),
    )
    import_cmd.add_argument("archive", metavar="<archive>", help="Migration archive to import.")
    import_cmd.add_argument("--target", required=True, metavar="<project>", help="New project path to restore into.")
    import_cmd.add_argument(
        "--read-only",
        action="store_true",
        help="Import an archive-profile migration as read_only_imported dashboard-only workflow history.",
    )
    _add_nested_workspace_options(import_cmd)
    import_cmd.add_argument("--json", action="store_true", help="Emit a machine-readable import report.")
    import_cmd.set_defaults(handler=run_import, command_path=("import",))


def add_dashboard_and_inspection_commands(subparsers: argparse._SubParsersAction[argparse.ArgumentParser]) -> None:
    dashboard = subparsers.add_parser(
        "dashboard",
        help="Generate, serve, or inspect workflow dashboards.",
        description=(
            "Generate a read-only static dashboard bundle, start a local dashboard server, "
            "or list workspace-scoped dashboard server records."
        ),
    )
    dashboard.add_argument(
        "dashboard_action",
        nargs="?",
        choices=("list", "cleanup", "stop", "benchmark"),
        help=(
            "Use 'list' to inspect dashboard server records, 'cleanup' to remove stale records, "
            "'stop' to terminate registered project dashboard servers, or 'benchmark' to measure "
            "dashboard loading paths."
        ),
    )
    dashboard.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    dashboard.add_argument(
        "--output",
        metavar="<path>",
        help="Output directory. Relative paths are resolved under the project root. Defaults to .loopplane/dashboard_static.",
    )
    dashboard.add_argument("--port", metavar="<port>", help="Start a local dashboard server on this port, or use 'auto'.")
    dashboard.add_argument(
        "--workflow",
        metavar="<workflow_id>",
        help=(
            "Select a workflow from .loopplane/workflow_registry.json for dashboard visualization "
            "without updating .loopplane/current_workflow.json."
        ),
    )
    dashboard.add_argument("--host", metavar="<host>", help="Dashboard bind host. Defaults to security/dashboard config host.")
    dashboard.add_argument("--rebuild-read-models", action="store_true", help="Rebuild derived read models before rendering.")
    dashboard.add_argument(
        "--max-dashboard-events",
        type=int,
        metavar="<count>",
        help="Maximum recent events included in dashboard graph/feed read models. Defaults to dashboard config or 200.",
    )
    dashboard.add_argument(
        "--embed-workflow-snapshots",
        action="store_true",
        help="For static dashboard generation, embed all workflow snapshots for offline workflow switching. This can produce large bundles.",
    )
    dashboard.add_argument(
        "--iterations",
        type=int,
        default=3,
        metavar="<count>",
        help="With 'benchmark', measured iterations per dashboard loading operation. Defaults to 3.",
    )
    dashboard.add_argument(
        "--warmups",
        type=int,
        default=1,
        metavar="<count>",
        help="With 'benchmark', unreported warmup iterations per dashboard loading operation. Defaults to 1.",
    )
    dashboard.add_argument(
        "--include-no-write-rebuild",
        action="store_true",
        help="With 'benchmark', also measure rebuild-read-models in no-write comparison mode.",
    )
    dashboard.add_argument(
        "--terminate-orphans",
        action="store_true",
        help="With 'cleanup' or 'stop', SIGTERM unregistered dashboard processes whose command line targets this project.",
    )
    _add_nested_workspace_options(dashboard)
    dashboard.add_argument("--json", action="store_true", help="Emit a machine-readable dashboard render report.")
    dashboard.set_defaults(handler=run_dashboard, command_path=("dashboard",), command_aliases=(("dashboard", "list"),))

    ask = subparsers.add_parser(
        "ask",
        help="Ask an inspection question about the workflow.",
        description="Ask a read-only workflow inspection question and write chat request/response records.",
    )
    ask.add_argument("question", nargs="?", help="Question to answer from workflow state.")
    ask.add_argument("--question", dest="question_option", help="Question to answer from workflow state. Alias for the positional argument.")
    ask.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    ask.add_argument("--runner", default="inspector", help="Inspector runner id to record. Defaults to inspector.")
    ask.add_argument(
        "--allowed-path",
        action="append",
        help="Restrict read scope to a configured inspector allowlist path. May be repeated.",
    )
    _add_nested_workspace_options(ask)
    ask.add_argument("--json", action="store_true", help="Emit a machine-readable inspection response.")
    ask.set_defaults(handler=run_inspection, command_path=("ask",))

    change_request = subparsers.add_parser(
        "change-request",
        help="Submit, review, inspect, or apply workflow change requests.",
        description=(
            "Append change requests and drive the planner response, approval, and reconciler patch flow. "
            "The shorthand `loopplane change-request \"...\"` is equivalent to `loopplane change-request submit \"...\"`."
        ),
    )
    change_request.set_defaults(handler=show_help, help_parser=change_request)
    change_subparsers = change_request.add_subparsers(
        dest="change_request_command",
        metavar="<change-request-command>",
        title="change request commands",
    )

    change_submit = change_subparsers.add_parser(
        "submit",
        help="Append a workflow change request.",
        description="Append a pending change request without mutating PLAN.md.",
    )
    change_submit.add_argument("request", nargs="?", help="Change request text.")
    change_submit.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    _add_nested_workspace_options(change_submit)
    change_submit.add_argument("--json", action="store_true", help="Emit a machine-readable change request report.")
    change_submit.set_defaults(handler=run_change_request_submit, command_path=("change-request", "submit"))

    change_review = change_subparsers.add_parser(
        "review",
        help="Run change request planner review and write PLAN_PATCH.md.",
        description="Review a pending change request, write planner response artifacts, and request approval when required.",
    )
    change_review.add_argument("change_request_id", nargs="?", help="Change request id. Defaults to the oldest pending request.")
    change_review.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    change_review.add_argument("--runner", help="Change-request planner runner id override.")
    change_review.add_argument("--audit", action="store_true", help="Write an optional plan patch audit report.")
    _add_nested_workspace_options(change_review)
    change_review.add_argument("--json", action="store_true", help="Emit a machine-readable change request report.")
    change_review.set_defaults(handler=run_change_request_review, command_path=("change-request", "review"))

    change_apply = change_subparsers.add_parser(
        "apply",
        help="Apply an approved change request PLAN_PATCH.md through reconciliation.",
        description="Apply an approved plan patch through reconciler-controlled code with before and after Git checkpoints.",
    )
    change_apply.add_argument("change_request_id", nargs="?", help="Change request id to apply.")
    change_apply.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    _add_nested_workspace_options(change_apply)
    change_apply.add_argument("--json", action="store_true", help="Emit a machine-readable change request report.")
    change_apply.set_defaults(handler=run_change_request_apply, command_path=("change-request", "apply"))

    change_status = change_subparsers.add_parser(
        "status",
        help="List change request status.",
        description="Show change request status derived from request, response, approval, and apply records.",
    )
    change_status.add_argument("change_request_id", nargs="?", help="Optional change request id to inspect.")
    change_status.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    change_status.add_argument("--all", action="store_true", help="Include applied, rejected, and superseded requests.")
    _add_nested_workspace_options(change_status)
    change_status.add_argument("--json", action="store_true", help="Emit a machine-readable change request status report.")
    change_status.set_defaults(handler=run_change_request_status, command_path=("change-request", "status"))

    approvals = subparsers.add_parser(
        "approvals",
        help="List pending approvals.",
        description="List approval requests and their current response status.",
    )
    approvals.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    approvals.add_argument("--all", action="store_true", help="Include closed approvals.")
    _add_nested_workspace_options(approvals)
    approvals.add_argument("--json", action="store_true", help="Emit machine-readable approval status.")
    approvals.set_defaults(handler=run_approvals, command_path=("approvals",))

    approve = subparsers.add_parser(
        "approve",
        help="Approve a pending approval request.",
        description="Record an approved human approval response when interactive approval is enabled.",
    )
    approve.add_argument("approval_id", nargs="?", help="Approval id to approve.")
    approve.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    approve.add_argument("--approved-by", default="user", help="Approver label to record. Defaults to user.")
    approve.add_argument("--notes", default="", help="Optional approval notes.")
    approve.add_argument(
        "--override-disabled-policy",
        action="store_true",
        help="Explicitly record the response even when interactive approval is disabled.",
    )
    _add_nested_workspace_options(approve)
    approve.add_argument("--json", action="store_true", help="Emit machine-readable approval response.")
    approve.set_defaults(handler=run_approve, command_path=("approve",))

    reject = subparsers.add_parser(
        "reject",
        help="Reject a pending approval request.",
        description="Record a rejected, expired, or superseded human approval response when interactive approval is enabled.",
    )
    reject.add_argument("approval_id", nargs="?", help="Approval id to reject.")
    reject.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    reject.add_argument(
        "--decision",
        choices=tuple(sorted(ALLOWED_APPROVAL_DECISIONS - {"approved"})),
        default="rejected",
        help="Decision to record. Defaults to rejected.",
    )
    reject.add_argument("--approved-by", default="user", help="Responder label to record. Defaults to user.")
    reject.add_argument("--notes", default="", help="Optional rejection notes.")
    reject.add_argument(
        "--override-disabled-policy",
        action="store_true",
        help="Explicitly record the response even when interactive approval is disabled.",
    )
    _add_nested_workspace_options(reject)
    reject.add_argument("--json", action="store_true", help="Emit machine-readable approval response.")
    reject.set_defaults(handler=run_reject, command_path=("reject",))


def add_self_expansion_commands(subparsers: argparse._SubParsersAction[argparse.ArgumentParser]) -> None:
    parser = subparsers.add_parser(
        "self-expansion",
        help="Inspect, validate, and apply self-expansion proposals.",
        description="Inspect LoopPlane self-expansion policy/registry and validate or apply generated expansion proposals.",
    )
    parser.set_defaults(handler=show_help, help_parser=parser)
    expansion_subparsers = parser.add_subparsers(
        dest="self_expansion_command",
        metavar="<self-expansion-command>",
        title="self-expansion commands",
    )

    status = expansion_subparsers.add_parser(
        "status",
        help="Show self-expansion status.",
        description="Show self-expansion policy, registry path, cycle count, and latest proposal.",
    )
    status.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    _add_nested_workspace_options(status)
    status.add_argument("--json", action="store_true", help="Emit machine-readable self-expansion status.")
    status.set_defaults(handler=run_self_expansion_status, command_path=("self-expansion", "status"))

    validate = expansion_subparsers.add_parser(
        "validate",
        help="Validate an expansion proposal.",
        description="Validate an expansion_proposal.json and its PLAN_PATCH.md without mutating PLAN.md.",
    )
    validate.add_argument("proposal", metavar="<proposal.json>", help="Expansion proposal JSON file.")
    validate.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    validate.add_argument("--write-registry", action="store_true", help="Record validation result in expansion_registry.json.")
    _add_nested_workspace_options(validate)
    validate.add_argument("--json", action="store_true", help="Emit machine-readable validation output.")
    validate.set_defaults(handler=run_self_expansion_validate, command_path=("self-expansion", "validate"))

    apply = expansion_subparsers.add_parser(
        "apply",
        help="Apply a validated expansion proposal.",
        description="Validate and apply an expansion proposal through the append-only PLAN patch reconciler.",
    )
    apply.add_argument("proposal", metavar="<proposal.json>", help="Expansion proposal JSON file.")
    apply.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    apply.add_argument("--run-id", help="Optional run id to attach to registry/event records.")
    apply.add_argument("--runner", help="Optional runner id to attach to registry records.")
    _add_nested_workspace_options(apply)
    apply.add_argument("--json", action="store_true", help="Emit machine-readable apply output.")
    apply.set_defaults(handler=run_self_expansion_apply, command_path=("self-expansion", "apply"))


def add_version_control_commands(subparsers: argparse._SubParsersAction[argparse.ArgumentParser]) -> None:
    parser = subparsers.add_parser(
        "vc",
        help="Version control status, checkpoint, diff, log, rollback, and doctor commands.",
        description="Version control commands.",
    )
    parser.set_defaults(handler=show_help, help_parser=parser)
    vc_subparsers = parser.add_subparsers(
        dest="vc_command",
        metavar="<vc-command>",
        title="version control commands",
    )

    status = vc_subparsers.add_parser(
        "status",
        help="Show version-control status.",
        description="Show concise sanitized version-control status for dashboard and CLI inspection.",
    )
    status.add_argument("--project", metavar="<path>", help="Project path to inspect. Defaults to the current directory.")
    _add_nested_workspace_options(status)
    status.add_argument("--json", action="store_true", help="Emit a machine-readable status report.")
    status.set_defaults(handler=run_vc_status, command_path=("vc", "status"))

    checkpoint = add_stub(vc_subparsers, "checkpoint", "Create a manual checkpoint.", command_path=("vc", "checkpoint"))
    checkpoint.add_argument("--project", metavar="<path>", help="Project path to checkpoint. Defaults to current directory.")
    checkpoint.add_argument("--reason", help="Manual checkpoint reason.")
    checkpoint.add_argument("--task", help="Task id associated with the checkpoint.")
    checkpoint.add_argument("--run", help="Run id associated with the checkpoint.")
    _add_nested_workspace_options(checkpoint)
    checkpoint.add_argument("--json", action="store_true", help="Emit a machine-readable checkpoint report.")
    checkpoint.set_defaults(handler=run_vc_checkpoint, command_path=("vc", "checkpoint"))

    run_metadata = add_stub(
        vc_subparsers,
        "run-metadata",
        "Capture Git metadata for a worker or recovery run.",
        command_path=("vc", "run-metadata"),
    )
    run_metadata.add_argument("--project", metavar="<path>", help="Project path. Defaults to current directory.")
    run_metadata.add_argument("--run-dir", required=True, metavar="<path>", help="Run evidence directory.")
    run_metadata.add_argument("--stage", required=True, choices=("pre", "post"), help="Capture stage.")
    run_metadata.add_argument("--task", required=True, help="Task id associated with the run.")
    run_metadata.add_argument("--run", required=True, help="Run id associated with the run.")
    run_metadata.add_argument(
        "--run-kind",
        choices=("worker", "recovery"),
        default="worker",
        help="Run kind. Defaults to worker.",
    )
    _add_nested_workspace_options(run_metadata)
    run_metadata.add_argument("--json", action="store_true", help="Emit a machine-readable metadata report.")
    run_metadata.set_defaults(handler=run_vc_run_metadata, command_path=("vc", "run-metadata"))

    diff = vc_subparsers.add_parser(
        "diff",
        help="Show checkpoint or task diff.",
        description="Show sanitized task/run diff metadata captured under a LoopPlane evidence run directory.",
    )
    diff.add_argument("--project", metavar="<path>", help="Project path to inspect. Defaults to the current directory.")
    diff.add_argument("--task", required=True, help="Task id whose diff should be shown.")
    _add_nested_workspace_options(diff)
    diff.add_argument("--json", action="store_true", help="Emit a machine-readable task diff report.")
    diff.set_defaults(handler=run_vc_diff, command_path=("vc", "diff"))

    log = vc_subparsers.add_parser(
        "log",
        help="Show checkpoint log.",
        description="Show sanitized checkpoint metadata from the LoopPlane checkpoint log.",
    )
    log.add_argument("--project", metavar="<path>", help="Project path to inspect. Defaults to the current directory.")
    _add_nested_workspace_options(log)
    log.add_argument("--json", action="store_true", help="Emit a machine-readable checkpoint log.")
    log.add_argument("--verbose-json", action="store_true", help="With --json, preserve any full file lists available in checkpoint records.")
    log.add_argument("--limit", type=int, help="Return at most this many checkpoints, newest first.")
    log.set_defaults(handler=run_vc_log, command_path=("vc", "log"))

    rollback = vc_subparsers.add_parser(
        "rollback",
        help="Request rollback to a checkpoint.",
        description=(
            "Create an approval-gated rollback request for a managed LoopPlane checkpoint. "
            "This command does not mutate the worktree or rewrite history."
        ),
    )
    rollback.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    rollback.add_argument("--checkpoint", required=True, help="Checkpoint id to roll back to.")
    _add_nested_workspace_options(rollback)
    rollback.add_argument("--json", action="store_true", help="Emit a machine-readable rollback request report.")
    rollback.set_defaults(handler=run_vc_rollback, command_path=("vc", "rollback"))

    export = vc_subparsers.add_parser(
        "export",
        help="Export LoopPlane-managed checkpoint refs to a Git bundle.",
        description=(
            "Create a standard Git bundle containing only LoopPlane-managed checkpoint refs under "
            "refs/loopplane/<workflow_id>/checkpoints. This command does not push, fetch, switch "
            "branches, rewrite history, or modify the user's index."
        ),
    )
    export.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    export.add_argument("--output", required=True, metavar="<bundle>", help="Git bundle path to create.")
    _add_nested_workspace_options(export)
    export.add_argument("--json", action="store_true", help="Emit a machine-readable bundle export report.")
    export.set_defaults(handler=run_vc_export, command_path=("vc", "export"))

    import_refs = vc_subparsers.add_parser(
        "import",
        help="Import LoopPlane-managed checkpoint refs from a Git bundle.",
        description=(
            "Import only LoopPlane-managed checkpoint refs under refs/loopplane/<workflow_id>/checkpoints "
            "from a standard Git bundle. Non-LoopPlane refs in the bundle are ignored; this command "
            "does not push, fetch remotes, switch branches, rewrite history, or modify the user's index."
        ),
    )
    import_refs.add_argument("bundle", metavar="<bundle>", help="Git bundle path to import.")
    import_refs.add_argument("--project", metavar="<path>", help="Project path. Defaults to the current directory.")
    _add_nested_workspace_options(import_refs)
    import_refs.add_argument("--json", action="store_true", help="Emit a machine-readable bundle import report.")
    import_refs.set_defaults(handler=run_vc_import, command_path=("vc", "import"))

    doctor = add_stub(vc_subparsers, "doctor", "Inspect version-control availability.", command_path=("vc", "doctor"))
    doctor.add_argument("--project", metavar="<path>", help="Project path to inspect. Defaults to the current directory.")
    _add_nested_workspace_options(doctor)
    doctor.add_argument("--json", action="store_true", help="Emit a machine-readable doctor report.")
    doctor.set_defaults(handler=run_vc_doctor, command_path=("vc", "doctor"))


def add_workspace_commands(subparsers: argparse._SubParsersAction[argparse.ArgumentParser]) -> None:
