def run_rebuild_read_models(args: argparse.Namespace) -> int:
    if getattr(args, "compare_rebuild", False) and not getattr(args, "strict_diagnostics", False):
        print("--compare-rebuild requires --strict-diagnostics", file=sys.stderr)
        return EXIT_INVALID_CONFIG
    if getattr(args, "strict_diagnostics", False):
        result = strict_read_model_diagnostics(
            Path(args.project or "."),
            workflow_id=getattr(args, "workflow", None),
            compare_rebuild=bool(getattr(args, "compare_rebuild", False)),
        )
        if args.json:
            print(json.dumps(result, indent=2, sort_keys=True))
        else:
            print(format_strict_read_model_diagnostics_text(result), end="")
        return read_model_rebuild_exit_code(result)
    result = rebuild_read_models(
        Path(args.project or "."),
        write=not args.no_write,
        workflow_id=getattr(args, "workflow", None),
        max_dashboard_events=getattr(args, "max_dashboard_events", None),
    )
    if args.json:
        print(json.dumps(result, indent=2, sort_keys=True))
    else:
        print(format_read_model_rebuild_text(result), end="")
    return read_model_rebuild_exit_code(result)


